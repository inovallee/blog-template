<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Blog{% endblock %}</title>
    {% block meta %}{% endblock %}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #1e3a5f;
            --primary-light: #2c5282;
            --accent: #3182ce;
            --bg: #f7fafc;
            --text: #2d3748;
            --text-light: #718096;
            --border: #e2e8f0;
        }
        body { font-family: 'Inter', -apple-system, sans-serif; color: var(--text); background: var(--bg); }
        a { color: var(--accent); text-decoration: none; }
        a:hover { color: var(--primary); }

        /* Navbar */
        .navbar-custom { background: var(--primary); padding: .8rem 0; }
        .navbar-custom .navbar-brand { color: #fff; font-weight: 700; font-size: 1.2rem; }
        .navbar-custom .nav-link { color: rgba(255,255,255,.8); font-weight: 500; font-size: .9rem; }
        .navbar-custom .nav-link:hover { color: #fff; }

        /* Hero */
        .hero { background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); color: #fff; padding: 4rem 0; }
        .hero h1 { font-weight: 700; font-size: 2.5rem; }
        .hero p { font-size: 1.1rem; opacity: .9; }

        /* Cards */
        .article-card { border: 1px solid var(--border); border-radius: 12px; overflow: hidden; transition: all .2s; background: #fff; }
        .article-card:hover { transform: translateY(-4px); box-shadow: 0 10px 40px rgba(0,0,0,.08); }
        .article-card .card-body { padding: 1.5rem; }
        .article-card .card-title { font-weight: 600; font-size: 1.1rem; color: var(--text); line-height: 1.4; }
        .article-card .card-text { color: var(--text-light); font-size: .9rem; line-height: 1.6; }
        .category-badge { font-size: .75rem; font-weight: 600; padding: .3rem .8rem; border-radius: 20px; }
        .badge-evergreen { background: #ebf8ff; color: #2b6cb0; }
        .badge-actualites { background: #fefcbf; color: #975a16; }

        /* Article */
        .article-content { font-size: 1.05rem; line-height: 1.9; color: var(--text); }
        .article-content h2 { font-weight: 700; font-size: 1.5rem; margin-top: 2.5rem; margin-bottom: 1rem; color: var(--primary); }
        .article-content h3 { font-weight: 600; font-size: 1.25rem; margin-top: 2rem; margin-bottom: .8rem; }
        .article-content p { margin-bottom: 1.2rem; }
        .article-content ul, .article-content ol { margin-bottom: 1.2rem; }
        .article-content li { margin-bottom: .4rem; line-height: 1.7; }
        .article-content blockquote { background: #f0f4f8; border-left: 4px solid var(--accent); padding: 1.2rem 1.5rem; margin: 1.5rem 0; border-radius: 0 8px 8px 0; font-style: italic; }
        .article-content table { width: 100%; margin: 1.5rem 0; }
        .article-content strong { color: var(--primary); }

        /* Footer */
        .footer { background: var(--primary); color: rgba(255,255,255,.7); padding: 2rem 0; margin-top: 4rem; }
        .footer a { color: rgba(255,255,255,.9); }

        /* Trust badges */
        .trust-bar { background: #fff; border-bottom: 1px solid var(--border); padding: .5rem 0; }
        .trust-item { font-size: .8rem; color: var(--text-light); }
        .trust-item i { color: var(--accent); }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <!-- Trust bar -->
    <div class="trust-bar">
        <div class="container d-flex justify-content-center gap-4">
            <span class="trust-item"><i class="bi bi-shield-check me-1"></i>Contenu expert vérifié</span>
            <span class="trust-item"><i class="bi bi-clock me-1"></i>Mis à jour régulièrement</span>
            <span class="trust-item"><i class="bi bi-graph-up me-1"></i>Données sourcées</span>
        </div>
    </div>

    <!-- Navbar -->
    <nav class="navbar navbar-custom navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_home') }}">
                <i class="bi bi-broadcast me-1"></i>{{ app.request.host }}
            </a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="{{ path('app_home') }}">Accueil</a>
                <a class="nav-link" href="{{ path('app_category_evergreen') }}">Guides</a>
                <a class="nav-link" href="{{ path('app_category_actualites') }}">Actualités</a>
            </div>
        </div>
    </nav>

    {% block hero %}{% endblock %}

    <div class="container py-4">
        {% block body %}{% endblock %}
    </div>

    <!-- Footer -->
    <footer class="footer">
        <div class="container text-center">
            <p class="mb-1"><strong>{{ app.request.host }}</strong></p>
            <p class="mb-2">
                <a href="{{ path('app_home') }}" class="me-3">Accueil</a>
                <a href="{{ path('app_category_evergreen') }}" class="me-3">Guides</a>
                <a href="{{ path('app_category_actualites') }}">Actualités</a>
            </p>
            <small>&copy; {{ "now"|date("Y") }} {{ app.request.host }}. Tous droits réservés.</small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>
