<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="max-image-preview:large">
    <title>{% block title %}Blog{% endblock %}</title>
    {% block meta %}{% endblock %}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #4a90d9;
            --primary-dark: #2d6cb5;
            --red: #d63031;
            --accent: #4a90d9;
            --accent-hover: #2d6cb5;
            --text: #333;
            --text-dark: #1a1a1a;
            --text-light: #777;
            --bg: #fff;
            --bg-alt: #f5f5f5;
            --border: #e0e0e0;
        }
        html { scroll-behavior: smooth; }
        body { font-family: 'Inter', -apple-system, sans-serif; color: var(--text); background: var(--bg); margin: 0; -webkit-font-smoothing: antialiased; font-size: 15px; }
        a { color: var(--accent); text-decoration: none; transition: color .2s; }
        a:hover { color: var(--accent-hover); }

        /* Reading progress bar */
        .reading-progress { position: fixed; top: 0; left: 0; height: 3px; background: var(--accent); width: 0%; z-index: 9999; transition: width .1s linear; }

        /* Header */
        .site-header { background: #fff; z-index: 100; border-bottom: 1px solid var(--border); }
        .header-inner { display: flex; align-items: center; justify-content: center; max-width: 1200px; margin: 0 auto; padding: .8rem 1.5rem; position: relative; }
        .site-logo { font-weight: 800; font-size: 1.8rem; color: #fff; letter-spacing: -.02em; background: var(--primary); padding: .3rem 1.2rem .15rem; display: inline-block; border-bottom: 4px solid var(--red); }
        .site-logo:hover { color: #fff; }
        .header-right { position: absolute; right: 1.5rem; display: flex; align-items: center; gap: 1rem; }
        .header-right a { color: var(--text); font-size: .82rem; font-weight: 600; }
        .header-right a:hover { color: var(--accent); }

        /* Top nav bar */
        .topnav { background: #fff; border-bottom: 1px solid var(--border); overflow-x: auto; white-space: nowrap; -webkit-overflow-scrolling: touch; }
        .topnav::-webkit-scrollbar { display: none; }
        .topnav-inner { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; display: flex; gap: 0; align-items: stretch; }
        .topnav a { color: var(--text); font-size: .82rem; font-weight: 600; padding: .6rem 1rem; display: inline-flex; align-items: center; border-bottom: 3px solid transparent; transition: all .15s; }
        .topnav a:hover { color: var(--accent); border-bottom-color: var(--red); }
        .topnav a.active { color: var(--accent); border-bottom-color: var(--red); }
        .topnav .sep { width: 1px; background: var(--border); margin: .4rem 0; }

        /* Ticker */
        .ticker-wrap { background: var(--primary-dark); overflow: hidden; white-space: nowrap; }
        .ticker { display: inline-flex; animation: ticker var(--ticker-duration, 45s) linear infinite; }
        .ticker:hover { animation-play-state: paused; }
        .ticker-item { display: inline-flex; align-items: center; padding: .35rem 2rem; font-size: .78rem; color: rgba(255,255,255,.9); font-weight: 500; }
        .ticker-item i { color: var(--red); margin-right: .4rem; }
        .ticker-item a { color: #fff; }
        .ticker-item a:hover { text-decoration: underline; color: #fff; }
        @keyframes ticker { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
        @media (prefers-reduced-motion: reduce) { .ticker { animation: none; } }

        /* Article layout */
        .article-wrapper { max-width: 1200px; margin: 0 auto; padding: 2rem 1.5rem; display: flex; gap: 3rem; }
        .article-main { flex: 1; min-width: 0; max-width: 780px; }
        .article-sidebar { width: 280px; flex-shrink: 0; }
        @media (max-width: 1024px) { .article-sidebar { display: none; } .article-wrapper { max-width: 780px; } }

        /* Breadcrumb */
        .breadcrumb { font-size: .8rem; margin-bottom: 1.5rem; }
        .breadcrumb a { color: var(--text-light); }
        .breadcrumb a:hover { color: var(--accent); }
        .breadcrumb-separator { color: var(--border); margin: 0 .4rem; }

        /* Article header */
        .article-header { margin-bottom: 1.5rem; }
        .article-header h1 { font-size: 2rem; font-weight: 800; color: var(--text-dark); line-height: 1.25; letter-spacing: -.03em; margin-bottom: 1rem; }
        .article-meta { display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; color: var(--text-light); font-size: .82rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border); }
        .article-meta i { font-size: .75rem; }
        .category-pill { background: var(--accent); color: #fff; font-size: .65rem; font-weight: 700; padding: .2rem .6rem; border-radius: 2px; text-transform: uppercase; letter-spacing: .05em; display: inline-block; }

        /* Article hero image */
        .article-hero-img { width: 100%; max-height: 440px; object-fit: cover; margin-bottom: 2rem; }

        /* Article content */
        .article-content { font-size: 1.05rem; line-height: 1.85; color: var(--text); }
        .article-content h2 { font-size: 1.45rem; font-weight: 700; color: var(--text-dark); margin: 2.5rem 0 1rem; padding-top: .5rem; }
        .article-content h3 { font-size: 1.15rem; font-weight: 600; color: var(--text-dark); margin: 1.8rem 0 .7rem; }
        .article-content p { margin-bottom: 1.3rem; }
        .article-content ul, .article-content ol { margin-bottom: 1.3rem; padding-left: 1.5rem; }
        .article-content li { margin-bottom: .4rem; line-height: 1.75; }
        .article-content strong { color: var(--text-dark); }
        .article-content blockquote { background: var(--bg-alt); border-left: 4px solid var(--accent); padding: 1.2rem 1.5rem; margin: 1.5rem 0; border-radius: 0 4px 4px 0; font-style: italic; color: var(--text-light); }
        .article-content table { width: 100%; margin: 1.5rem 0; border-collapse: collapse; font-size: .92rem; }
        .article-content table th { background: var(--primary); color: #fff; padding: .6rem .8rem; text-align: left; font-size: .82rem; font-weight: 600; }
        .article-content table td { padding: .6rem .8rem; border-bottom: 1px solid var(--border); }
        .article-content table tr:hover td { background: var(--bg-alt); }
        .article-content a { color: var(--accent); text-decoration: underline; text-decoration-color: rgba(0,96,170,.3); text-underline-offset: 2px; }
        .article-content a:hover { text-decoration-color: var(--accent); }

        /* TOC sidebar */
        .toc-sticky { position: sticky; top: 80px; }
        .toc-box { background: var(--bg-alt); border-radius: 4px; padding: 1.2rem; border: 1px solid var(--border); }
        .toc-title { font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--text-light); margin-bottom: .8rem; display: flex; align-items: center; gap: .4rem; }
        .toc-list { list-style: none; padding: 0; margin: 0; }
        .toc-list li { margin-bottom: .2rem; }
        .toc-list a { font-size: .82rem; color: var(--text-light); display: block; padding: .35rem .8rem; border-left: 2px solid transparent; transition: all .2s; line-height: 1.4; }
        .toc-list a:hover { color: var(--text); background: rgba(0,0,0,.03); }
        .toc-list a.highlight { color: var(--accent); border-left-color: var(--accent); font-weight: 600; }

        /* Sources box */
        .sources-box { background: var(--bg-alt); border: 1px solid var(--border); border-radius: 4px; padding: 1.5rem; margin-top: 2.5rem; }
        .sources-box h3 { font-size: .85rem; font-weight: 700; color: var(--text-dark); margin-bottom: .8rem; }
        .sources-box ol { font-size: .85rem; padding-left: 1.2rem; color: var(--text-light); }
        .sources-box li { margin-bottom: .4rem; }

        /* Tags */
        .tags-list { display: flex; flex-wrap: wrap; gap: .4rem; margin-top: 1.5rem; }
        .tag-badge { background: var(--bg-alt); color: var(--text); font-size: .75rem; font-weight: 500; padding: .25rem .6rem; border-radius: 2px; border: 1px solid var(--border); }

        /* CTA */
        .article-cta { background: var(--primary-dark); border-radius: 4px; padding: 2.5rem; text-align: center; color: #fff; margin-top: 3rem; }
        .article-cta h3 { font-weight: 800; font-size: 1.2rem; margin-bottom: .5rem; }
        .article-cta p { opacity: .7; font-size: .95rem; margin-bottom: 1rem; }
        .article-cta .btn { background: var(--accent); border: none; color: #fff; padding: .5rem 1.5rem; border-radius: 4px; font-weight: 700; font-size: .9rem; }
        .article-cta .btn:hover { background: var(--accent-hover); }

        /* Cards */
        .article-card { background: #fff; border: 1px solid var(--border); overflow: hidden; transition: box-shadow .2s; }
        .article-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,.08); }
        .article-card img { width: 100%; aspect-ratio: 16/9; object-fit: cover; }
        .article-card .card-body { padding: 1rem; }
        .article-card .card-title { font-weight: 700; font-size: .95rem; color: var(--text-dark); line-height: 1.35; }
        .article-card .card-title a { color: var(--text-dark); }
        .article-card .card-title a:hover { color: var(--accent); }
        .article-card .card-text { color: var(--text-light); font-size: .82rem; line-height: 1.5; }

        /* Section headers */
        .section-header { border-bottom: 2px solid var(--text-dark); padding-bottom: .5rem; margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: baseline; }
        .section-header h2 { font-weight: 800; font-size: 1.15rem; margin: 0; }
        .section-header a { font-size: .82rem; font-weight: 600; }

        /* Sidebar "En continu" */
        .sidebar-continu { border-left: 3px solid var(--accent); }
        .sidebar-continu h4 { font-weight: 800; font-size: 1rem; margin-bottom: 1rem; padding-left: 1rem; }
        .sidebar-item { padding: .6rem 1rem; border-bottom: 1px solid var(--border); }
        .sidebar-item:last-child { border-bottom: none; }
        .sidebar-item a { color: var(--text-dark); font-size: .85rem; font-weight: 600; line-height: 1.4; display: block; }
        .sidebar-item a:hover { color: var(--accent); }
        .sidebar-item .meta { color: var(--text-light); font-size: .72rem; margin-top: .15rem; }

        /* Pagination */
        .page-link { color: var(--text-dark); border-color: var(--border); font-size: .85rem; }
        .page-item.active .page-link { background: var(--accent); border-color: var(--accent); }

        /* Misc */
        .reading-time { color: var(--text-light); font-size: .8rem; }
        .info-box { background: var(--bg-alt); border: 1px solid var(--border); border-radius: 4px; padding: .8rem 1rem; font-size: .8rem; color: var(--text-light); }

        /* Footer */
        .site-footer { background: var(--primary-dark); color: rgba(255,255,255,.6); padding: 2rem 0 1rem; margin-top: 3rem; }
        .site-footer a { color: rgba(255,255,255,.75); }
        .site-footer a:hover { color: #fff; }
        .footer-inner { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

        @media (max-width: 768px) {
            .article-header h1 { font-size: 1.6rem; }
            .site-logo { font-size: 1.3rem; }
            .header-right { display: none; }
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
    {% block progress %}{% endblock %}

    <!-- Header -->
    <header class="site-header">
        <div class="header-inner">
            <a class="site-logo" href="{{ path('app_home') }}">{{ app.request.host }}</a>
            <div class="header-right d-none d-md-flex">
                <a href="{{ path('app_category_actualites') }}">Actualités</a>
                <a href="{{ path('app_category_evergreen') }}">Guides</a>
            </div>
            <button class="btn d-md-none border-0 position-absolute" style="right:1rem;" type="button" data-bs-toggle="collapse" data-bs-target="#mobileNav">
                <i class="bi bi-list fs-4"></i>
            </button>
        </div>
        <div class="collapse d-md-none" id="mobileNav">
            <div class="p-3 d-flex flex-column gap-2 border-top">
                <a href="{{ path('app_home') }}" class="text-dark fw-semibold">Accueil</a>
                <a href="{{ path('app_category_actualites') }}" class="text-dark fw-semibold">Actualités</a>
                <a href="{{ path('app_category_evergreen') }}" class="text-dark fw-semibold">Guides</a>
            </div>
        </div>
    </header>

    {% block topnav %}{% endblock %}
    {% block ticker %}{% endblock %}

    {% block body_wrapper %}
    <div style="max-width:1200px; margin:0 auto; padding:2rem 1.5rem;">
        {% block body %}{% endblock %}
    </div>
    {% endblock %}

    <!-- Footer -->
    <footer class="site-footer">
        <div class="footer-inner">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <strong style="color:#fff;">{{ app.request.host }}</strong>
                    <span style="font-size:.82rem; margin-left:1rem;">Guides et actualités</span>
                </div>
                <div style="font-size:.82rem;">
                    <a href="{{ path('app_home') }}" class="me-3">Accueil</a>
                    <a href="{{ path('app_category_evergreen') }}" class="me-3">Guides</a>
                    <a href="{{ path('app_category_actualites') }}" class="me-3">Actualités</a>
                    <a href="{{ path('app_sitemap') }}">Plan du site</a>
                </div>
            </div>
            <hr style="border-color:rgba(255,255,255,.1);">
            <div class="text-center" style="font-size:.72rem;">&copy; {{ "now"|date("Y") }} {{ app.request.host }}</div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const ticker = document.querySelector('.ticker');
        if (ticker) {
            const duration = Math.max(20, ticker.scrollWidth / 50);
            ticker.style.setProperty('--ticker-duration', duration + 's');
        }
    });
    </script>
    {% block javascripts %}{% endblock %}
</body>
</html>
