<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="max-image-preview:large">
    <title>{% block title %}Blog{% endblock %}</title>
    {% block meta %}{% endblock %}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #213756;
            --accent: #316BFF;
            --accent-hover: #2859d6;
            --accent-light: #edf2ff;
            --text: #5f6c7b;
            --text-dark: #213756;
            --text-light: #8193a8;
            --bg: #fff;
            --bg-alt: #f9fafb;
            --border: #e5e9ef;
        }
        html { scroll-behavior: smooth; }
        body { font-family: 'Inter', -apple-system, sans-serif; color: var(--text); background: var(--bg); margin: 0; -webkit-font-smoothing: antialiased; }
        a { color: var(--accent); text-decoration: none; transition: color .2s; }
        a:hover { color: var(--accent-hover); }

        /* Reading progress bar */
        .reading-progress { position: fixed; top: 0; left: 0; height: 3px; background: linear-gradient(90deg, var(--accent), #7c3aed); width: 0%; z-index: 9999; transition: width .1s linear; }

        /* Header */
        .site-header { position: sticky; top: 0; background: #fff; z-index: 100; border-bottom: 1px solid var(--border); }
        .header-inner { display: flex; align-items: center; justify-content: space-between; max-width: 1200px; margin: 0 auto; padding: .6rem 1.5rem; }
        .site-logo { font-weight: 800; font-size: 1.15rem; color: var(--text-dark); letter-spacing: -.02em; }
        .site-logo:hover { color: var(--text-dark); }
        .site-nav { display: flex; gap: .5rem; align-items: center; }
        .site-nav a { color: var(--text-light); font-size: .875rem; font-weight: 500; padding: .4rem .8rem; border-radius: 8px; transition: all .2s; }
        .site-nav a:hover, .site-nav a.active { color: var(--text); background: var(--bg-alt); }

        /* Categories bar */
        .categories-bar { background: var(--bg-alt); border-bottom: 1px solid var(--border); }
        .categories-inner { max-width: 1200px; margin: 0 auto; padding: .4rem 1.5rem; display: flex; gap: 1.5rem; align-items: center; }
        .categories-inner a { color: var(--text-light); font-size: .8rem; font-weight: 600; transition: color .2s; }
        .categories-inner a:hover, .categories-inner a.active { color: var(--accent); }
        .categories-inner a:not(:last-child) { border-right: 1px solid var(--border); padding-right: 1.5rem; }

        /* Ticker */
        .ticker-wrap { background: var(--primary); overflow: hidden; white-space: nowrap; }
        .ticker { display: inline-flex; animation: ticker 45s linear infinite; }
        .ticker:hover { animation-play-state: paused; }
        .ticker-item { display: inline-flex; align-items: center; padding: .4rem 2rem; font-size: .78rem; color: rgba(255,255,255,.85); font-weight: 500; }
        .ticker-item i { color: var(--accent); margin-right: .4rem; }
        .ticker-item a { color: #fff; }
        .ticker-item a:hover { text-decoration: underline; color: #fff; }
        @keyframes ticker { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
        @media (prefers-reduced-motion: reduce) { .ticker { animation: none; } }

        /* Article layout */
        .article-wrapper { max-width: 1200px; margin: 0 auto; padding: 2rem 1.5rem; display: flex; gap: 3rem; }
        .article-main { flex: 1; min-width: 0; max-width: 780px; }
        .article-sidebar { width: 280px; flex-shrink: 0; }
        @media (max-width: 1024px) { .article-sidebar { display: none; } .article-wrapper { max-width: 780px; } }

        /* Breadcrumb */
        .breadcrumb { font-size: .8rem; margin-bottom: 1.5rem; }
        .breadcrumb a { color: var(--text-light); }
        .breadcrumb a:hover { color: var(--accent); }
        .breadcrumb-separator { color: var(--border); margin: 0 .4rem; }

        /* Article header */
        .article-header { margin-bottom: 2rem; }
        .article-header h1 { font-size: 2rem; font-weight: 800; color: var(--text-dark); line-height: 1.25; letter-spacing: -.03em; margin-bottom: 1rem; }
        .article-meta { display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; color: var(--text-light); font-size: .82rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
        .article-meta i { font-size: .75rem; }
        .category-pill { background: var(--bg-alt); color: var(--text); font-size: .7rem; font-weight: 700; padding: .25rem .7rem; border-radius: 20px; text-transform: uppercase; letter-spacing: .04em; }

        /* Article content */
        .article-content { font-size: 1.05rem; line-height: 1.85; color: var(--text); }
        .article-content h2 { font-size: 1.45rem; font-weight: 700; color: var(--text-dark); margin: 2.5rem 0 1rem; padding-top: .5rem; }
        .article-content h3 { font-size: 1.15rem; font-weight: 600; color: var(--text-dark); margin: 1.8rem 0 .7rem; }
        .article-content p { margin-bottom: 1.3rem; }
        .article-content ul, .article-content ol { margin-bottom: 1.3rem; padding-left: 1.5rem; }
        .article-content li { margin-bottom: .4rem; line-height: 1.75; }
        .article-content strong { color: var(--text-dark); }
        .article-content blockquote { background: var(--bg-alt); border-left: 4px solid var(--accent); padding: 1.2rem 1.5rem; margin: 1.5rem 0; border-radius: 0 8px 8px 0; font-style: italic; color: var(--text-light); }
        .article-content table { width: 100%; margin: 1.5rem 0; border-collapse: collapse; font-size: .92rem; }
        .article-content table th { background: var(--primary); color: #fff; padding: .6rem .8rem; text-align: left; font-size: .82rem; font-weight: 600; }
        .article-content table td { padding: .6rem .8rem; border-bottom: 1px solid var(--border); }
        .article-content table tr:hover td { background: var(--bg-alt); }
        .article-content a { color: var(--accent); text-decoration: underline; text-decoration-color: rgba(35,181,193,.3); text-underline-offset: 2px; }
        .article-content a:hover { text-decoration-color: var(--accent); }

        /* TOC sidebar */
        .toc-sticky { position: sticky; top: 80px; }
        .toc-box { background: var(--bg-alt); border-radius: 12px; padding: 1.2rem; }
        .toc-title { font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--text-light); margin-bottom: .8rem; display: flex; align-items: center; gap: .4rem; }
        .toc-list { list-style: none; padding: 0; margin: 0; }
        .toc-list li { margin-bottom: .2rem; }
        .toc-list a { font-size: .82rem; color: var(--text-light); display: block; padding: .35rem .8rem; border-left: 2px solid transparent; border-radius: 0 6px 6px 0; transition: all .2s; line-height: 1.4; }
        .toc-list a:hover { color: var(--text); background: rgba(0,0,0,.03); }
        .toc-list a.highlight { color: var(--accent); border-left-color: var(--accent); font-weight: 600; background: rgba(35,181,193,.06); }

        /* Sources box */
        .sources-box { background: var(--bg-alt); border-radius: 12px; padding: 1.5rem; margin-top: 2.5rem; }
        .sources-box h3 { font-size: .85rem; font-weight: 700; color: var(--text-dark); margin-bottom: .8rem; }
        .sources-box ol { font-size: .85rem; padding-left: 1.2rem; color: var(--text-light); }
        .sources-box li { margin-bottom: .4rem; }

        /* Tags */
        .tags-list { display: flex; flex-wrap: wrap; gap: .4rem; margin-top: 1.5rem; }
        .tag-badge { background: var(--bg-alt); color: var(--text); font-size: .75rem; font-weight: 500; padding: .25rem .6rem; border-radius: 6px; border: 1px solid var(--border); }

        /* CTA */
        .article-cta { background: linear-gradient(135deg, var(--primary) 0%, #1a3a5f 100%); border-radius: 16px; padding: 2.5rem; text-align: center; color: #fff; margin-top: 3rem; }
        .article-cta h3 { font-weight: 800; font-size: 1.2rem; margin-bottom: .5rem; }
        .article-cta p { opacity: .8; font-size: .95rem; margin-bottom: 1rem; }
        .article-cta .btn { background: var(--accent); border: none; color: #fff; padding: .5rem 1.5rem; border-radius: 8px; font-weight: 600; font-size: .9rem; box-shadow: 0 2px 8px rgba(49,107,255,.25); }
        .article-cta .btn:hover { background: var(--accent-hover); transform: translateY(-1px); box-shadow: 0 4px 12px rgba(49,107,255,.3); }

        /* Cards */
        .article-card { background: #fff; border: 1px solid var(--border); border-radius: 12px; transition: all .25s ease; overflow: hidden; }
        .article-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,.06); }
        .article-card .card-body { padding: 1.3rem; }
        .article-card .card-title { font-weight: 700; font-size: 1rem; color: var(--text-dark); line-height: 1.4; }
        .article-card .card-text { color: var(--text-light); font-size: .85rem; line-height: 1.6; }

        /* Hero (homepage) */
        .hero { background: linear-gradient(135deg, var(--primary) 0%, #1a3a5f 50%, #0d2847 100%); color: #fff; padding: 3rem 0; }
        .hero h1 { font-weight: 800; font-size: 2.2rem; letter-spacing: -.03em; }
        .hero p { opacity: .8; font-size: 1rem; }
        .hero-stat .num { font-size: 1.6rem; font-weight: 800; }
        .hero-stat .label { font-size: .7rem; opacity: .6; text-transform: uppercase; letter-spacing: .05em; }

        /* Featured */
        .featured { border: 2px solid var(--accent); border-radius: 14px; background: rgba(35,181,193,.03); }

        /* Footer */
        .site-footer { background: var(--primary); color: rgba(255,255,255,.6); padding: 2.5rem 0 1.5rem; margin-top: 4rem; }
        .site-footer a { color: rgba(255,255,255,.75); }
        .site-footer a:hover { color: #fff; }
        .site-footer h6 { color: #fff; font-size: .8rem; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; margin-bottom: .8rem; }
        .footer-inner { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

        /* Misc */
        .reading-time { color: var(--text-light); font-size: .8rem; }
        .info-box { background: var(--bg-alt); border-radius: 8px; padding: .8rem 1rem; font-size: .8rem; color: var(--text-light); border: 1px solid var(--border); }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
    {% block progress %}{% endblock %}

    <!-- Header -->
    <header class="site-header">
        <div class="header-inner">
            <a class="site-logo" href="{{ path('app_home') }}">
                <i class="bi bi-broadcast me-1"></i>{{ app.request.host }}
            </a>
            <nav class="site-nav d-none d-md-flex">
                <a href="{{ path('app_home') }}">Accueil</a>
                <a href="{{ path('app_category_evergreen') }}">Guides</a>
                <a href="{{ path('app_category_actualites') }}">Actualités</a>
            </nav>
            <button class="btn d-md-none border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mobileNav">
                <i class="bi bi-list fs-4"></i>
            </button>
        </div>
        <div class="collapse d-md-none" id="mobileNav">
            <div class="p-3 d-flex flex-column gap-2 border-top">
                <a href="{{ path('app_home') }}" class="text-dark">Accueil</a>
                <a href="{{ path('app_category_evergreen') }}" class="text-dark">Guides</a>
                <a href="{{ path('app_category_actualites') }}" class="text-dark">Actualités</a>
            </div>
        </div>
    </header>

    <!-- Categories bar -->
    <div class="categories-bar d-none d-md-block">
        <div class="categories-inner">
            <a href="{{ path('app_category_evergreen') }}">Guides</a>
            <a href="{{ path('app_category_actualites') }}">Actualités</a>
        </div>
    </div>

    {% block ticker %}{% endblock %}
    {% block hero %}{% endblock %}

    {% block body_wrapper %}
    <div style="max-width:1200px; margin:0 auto; padding:2rem 1.5rem;">
        {% block body %}{% endblock %}
    </div>
    {% endblock %}

    <!-- Footer -->
    <footer class="site-footer">
        <div class="footer-inner">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <h6><i class="bi bi-broadcast me-1"></i>{{ app.request.host }}</h6>
                    <p style="font-size:.82rem;">Guides experts, analyses et actualités pour professionnels.</p>
                </div>
                <div class="col-md-4 mb-3">
                    <h6>Navigation</h6>
                    <ul class="list-unstyled" style="font-size:.82rem;">
                        <li class="mb-1"><a href="{{ path('app_home') }}">Accueil</a></li>
                        <li class="mb-1"><a href="{{ path('app_category_evergreen') }}">Guides</a></li>
                        <li class="mb-1"><a href="{{ path('app_category_actualites') }}">Actualités</a></li>
                        <li class="mb-1"><a href="{{ path('app_sitemap') }}">Plan du site</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-3">
                    <h6>Confiance</h6>
                    <ul class="list-unstyled" style="font-size:.82rem;">
                        <li class="mb-1"><i class="bi bi-check-circle me-1" style="color:var(--accent)"></i>Contenu vérifié par des experts</li>
                        <li class="mb-1"><i class="bi bi-check-circle me-1" style="color:var(--accent)"></i>Sources citées et vérifiables</li>
                        <li class="mb-1"><i class="bi bi-check-circle me-1" style="color:var(--accent)"></i>Mis à jour régulièrement</li>
                    </ul>
                </div>
            </div>
            <hr style="border-color:rgba(255,255,255,.1);">
            <div class="text-center" style="font-size:.75rem;">&copy; {{ "now"|date("Y") }} {{ app.request.host }}. Tous droits réservés.</div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>
