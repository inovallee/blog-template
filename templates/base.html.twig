<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Blog{% endblock %}</title>
    {% block meta %}{% endblock %}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #0f172a;
            --primary-light: #1e293b;
            --accent: #2563eb;
            --accent-light: #3b82f6;
            --bg: #f8fafc;
            --text: #1e293b;
            --text-light: #64748b;
            --border: #e2e8f0;
            --success: #10b981;
            --warning: #f59e0b;
        }
        body { font-family: 'Inter', -apple-system, sans-serif; color: var(--text); background: var(--bg); }
        a { color: var(--accent); text-decoration: none; transition: color .2s; }
        a:hover { color: var(--primary); }

        /* Navbar */
        .navbar-custom { background: var(--primary); padding: .6rem 0; position: sticky; top: 0; z-index: 1000; }
        .navbar-custom .navbar-brand { color: #fff; font-weight: 800; font-size: 1.15rem; letter-spacing: -.02em; }
        .navbar-custom .nav-link { color: rgba(255,255,255,.75); font-weight: 500; font-size: .85rem; padding: .4rem .8rem !important; border-radius: 6px; transition: all .2s; }
        .navbar-custom .nav-link:hover { color: #fff; background: rgba(255,255,255,.1); }

        /* Ticker */
        .ticker-wrap { background: var(--accent); overflow: hidden; white-space: nowrap; }
        .ticker { display: inline-flex; animation: ticker 40s linear infinite; }
        .ticker-item { display: inline-flex; align-items: center; padding: .45rem 2rem; font-size: .8rem; color: #fff; font-weight: 500; }
        .ticker-item i { margin-right: .4rem; }
        .ticker-item a { color: #fff; text-decoration: none; }
        .ticker-item a:hover { text-decoration: underline; }
        @keyframes ticker { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

        /* Hero */
        .hero { background: linear-gradient(135deg, var(--primary) 0%, #1e3a5f 50%, var(--accent) 100%); color: #fff; padding: 3.5rem 0 3rem; position: relative; overflow: hidden; }
        .hero::after { content: ''; position: absolute; top: 0; right: 0; width: 40%; height: 100%; background: url("data:image/svg+xml,%3Csvg width='60' height='60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M30 0L60 30L30 60L0 30Z' fill='rgba(255,255,255,0.03)'/%3E%3C/svg%3E") repeat; }
        .hero h1 { font-weight: 800; font-size: 2.2rem; letter-spacing: -.03em; line-height: 1.2; }
        .hero p { font-size: 1.05rem; opacity: .85; }
        .hero-stat { text-align: center; }
        .hero-stat .stat-num { font-size: 1.8rem; font-weight: 800; }
        .hero-stat .stat-label { font-size: .75rem; opacity: .7; text-transform: uppercase; letter-spacing: .05em; }

        /* Cards */
        .article-card { border: 1px solid var(--border); border-radius: 12px; overflow: hidden; transition: all .25s ease; background: #fff; }
        .article-card:hover { transform: translateY(-6px); box-shadow: 0 20px 40px rgba(0,0,0,.08); border-color: var(--accent-light); }
        .article-card .card-body { padding: 1.5rem; }
        .article-card .card-title { font-weight: 700; font-size: 1.05rem; color: var(--text); line-height: 1.4; letter-spacing: -.01em; }
        .article-card .card-text { color: var(--text-light); font-size: .88rem; line-height: 1.6; }
        .category-badge { font-size: .7rem; font-weight: 700; padding: .25rem .7rem; border-radius: 20px; text-transform: uppercase; letter-spacing: .04em; }
        .badge-evergreen { background: #ecfdf5; color: #059669; }
        .badge-actualites { background: #fef3c7; color: #d97706; }
        .reading-time { font-size: .78rem; color: var(--text-light); }

        /* Featured card */
        .featured-card { border: 2px solid var(--accent); border-radius: 16px; background: linear-gradient(135deg, #eff6ff 0%, #fff 100%); }
        .featured-card:hover { border-color: var(--primary); }
        .featured-label { background: var(--accent); color: #fff; font-size: .7rem; font-weight: 700; padding: .2rem .6rem; border-radius: 4px; text-transform: uppercase; }

        /* Article */
        .article-content { font-size: 1.08rem; line-height: 1.9; color: var(--text); }
        .article-content h2 { font-weight: 800; font-size: 1.5rem; margin-top: 2.5rem; margin-bottom: 1rem; color: var(--primary); padding-bottom: .5rem; border-bottom: 2px solid var(--border); }
        .article-content h3 { font-weight: 700; font-size: 1.2rem; margin-top: 2rem; margin-bottom: .8rem; color: var(--primary-light); }
        .article-content p { margin-bottom: 1.2rem; }
        .article-content ul, .article-content ol { margin-bottom: 1.2rem; }
        .article-content li { margin-bottom: .5rem; line-height: 1.7; }
        .article-content blockquote { background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%); border-left: 4px solid var(--accent); padding: 1.2rem 1.5rem; margin: 1.5rem 0; border-radius: 0 12px 12px 0; font-style: italic; }
        .article-content table { width: 100%; margin: 1.5rem 0; border-collapse: collapse; }
        .article-content table th { background: var(--primary); color: #fff; padding: .6rem .8rem; font-size: .85rem; }
        .article-content table td { padding: .6rem .8rem; border-bottom: 1px solid var(--border); font-size: .9rem; }
        .article-content table tr:hover { background: #f8fafc; }
        .article-content strong { color: var(--primary); }

        /* TOC */
        .toc { position: sticky; top: 80px; }
        .toc-title { font-size: .8rem; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: var(--text-light); margin-bottom: .8rem; }
        .toc-list { list-style: none; padding: 0; }
        .toc-list li { margin-bottom: .4rem; }
        .toc-list a { font-size: .85rem; color: var(--text-light); display: block; padding: .3rem .8rem; border-left: 2px solid var(--border); transition: all .2s; }
        .toc-list a:hover, .toc-list a.active { color: var(--accent); border-left-color: var(--accent); background: #f0f9ff; }

        /* Footer */
        .footer { background: var(--primary); color: rgba(255,255,255,.6); padding: 3rem 0 2rem; margin-top: 4rem; }
        .footer a { color: rgba(255,255,255,.8); transition: color .2s; }
        .footer a:hover { color: #fff; }
        .footer h6 { color: #fff; font-weight: 700; font-size: .85rem; text-transform: uppercase; letter-spacing: .05em; margin-bottom: 1rem; }

        /* Trust badges */
        .trust-bar { background: #fff; border-bottom: 1px solid var(--border); padding: .4rem 0; }
        .trust-item { font-size: .75rem; color: var(--text-light); font-weight: 500; }
        .trust-item i { color: var(--success); }

        /* Animations */
        @media (prefers-reduced-motion: no-preference) {
            .fade-up { opacity: 0; transform: translateY(20px); animation: fadeUp .5s ease forwards; }
            @keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }
            .fade-up:nth-child(2) { animation-delay: .1s; }
            .fade-up:nth-child(3) { animation-delay: .2s; }
            .fade-up:nth-child(4) { animation-delay: .3s; }
            .fade-up:nth-child(5) { animation-delay: .4s; }
            .fade-up:nth-child(6) { animation-delay: .5s; }
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <!-- Trust bar -->
    <div class="trust-bar d-none d-md-block">
        <div class="container d-flex justify-content-center gap-4">
            <span class="trust-item"><i class="bi bi-shield-check me-1"></i>Contenu expert vérifié</span>
            <span class="trust-item"><i class="bi bi-clock me-1"></i>Mis à jour régulièrement</span>
            <span class="trust-item"><i class="bi bi-graph-up me-1"></i>Données sourcées</span>
        </div>
    </div>

    <!-- Navbar -->
    <nav class="navbar navbar-custom navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_home') }}">
                <i class="bi bi-broadcast me-1"></i>{{ app.request.host }}
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <i class="bi bi-list text-white fs-4"></i>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <div class="navbar-nav ms-auto">
                    <a class="nav-link" href="{{ path('app_home') }}">Accueil</a>
                    <a class="nav-link" href="{{ path('app_category_evergreen') }}">Guides</a>
                    <a class="nav-link" href="{{ path('app_category_actualites') }}">Actualités</a>
                </div>
            </div>
        </div>
    </nav>

    {% block ticker %}{% endblock %}
    {% block hero %}{% endblock %}

    <div class="container py-4">
        {% block body %}{% endblock %}
    </div>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <h6><i class="bi bi-broadcast me-1"></i>{{ app.request.host }}</h6>
                    <p style="font-size:.85rem;">Guides experts, analyses approfondies et actualités pour professionnels du secteur.</p>
                </div>
                <div class="col-md-4 mb-3">
                    <h6>Navigation</h6>
                    <ul class="list-unstyled" style="font-size:.85rem;">
                        <li class="mb-1"><a href="{{ path('app_home') }}">Accueil</a></li>
                        <li class="mb-1"><a href="{{ path('app_category_evergreen') }}">Guides</a></li>
                        <li class="mb-1"><a href="{{ path('app_category_actualites') }}">Actualités</a></li>
                        <li class="mb-1"><a href="{{ path('app_sitemap') }}">Plan du site</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-3">
                    <h6>Confiance</h6>
                    <ul class="list-unstyled" style="font-size:.85rem;">
                        <li class="mb-1"><i class="bi bi-check-circle me-1"></i>Contenu vérifié par des experts</li>
                        <li class="mb-1"><i class="bi bi-check-circle me-1"></i>Sources citées et vérifiables</li>
                        <li class="mb-1"><i class="bi bi-check-circle me-1"></i>Mis à jour régulièrement</li>
                    </ul>
                </div>
            </div>
            <hr style="border-color: rgba(255,255,255,.1);">
            <div class="text-center" style="font-size:.8rem;">
                &copy; {{ "now"|date("Y") }} {{ app.request.host }}. Tous droits réservés.
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>
