<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
    <url><loc>https://{{ app.request.host }}/</loc><priority>1.0</priority><changefreq>hourly</changefreq></url>
    <url><loc>https://{{ app.request.host }}/guides</loc><priority>0.8</priority><changefreq>daily</changefreq></url>
    <url><loc>https://{{ app.request.host }}/actualites</loc><priority>0.9</priority><changefreq>hourly</changefreq></url>
    {% for city in cities %}
    <url>
        <loc>https://{{ app.request.host }}/ville/{{ city.city|lower|replace({' ': '-'}) }}</loc>
        <priority>0.8</priority>
        <changefreq>daily</changefreq>
    </url>
    {% endfor %}
    {% for type in types %}
    <url>
        <loc>https://{{ app.request.host }}/type/{{ type }}</loc>
        <priority>0.7</priority>
        <changefreq>daily</changefreq>
    </url>
    {% endfor %}
    {% for article in articles %}
    <url>
        <loc>https://{{ app.request.host }}/{{ article.slug }}</loc>
        <lastmod>{{ article.deployedAt ? article.deployedAt|date('Y-m-d') : (article.publishedAt ? article.publishedAt|date('Y-m-d') : article.createdAt|date('Y-m-d')) }}</lastmod>
        <priority>0.7</priority>
    </url>
    {% endfor %}
</urlset>
