<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
    <url><loc>https://{{ domain }}/</loc><priority>1.0</priority></url>
    <url><loc>https://{{ domain }}/evergreen</loc><priority>0.8</priority></url>
    <url><loc>https://{{ domain }}/actualites</loc><priority>0.8</priority></url>
    {% for article in articles %}
    <url>
        <loc>https://{{ domain }}/{{ article.slug }}</loc>
        <lastmod>{{ article.publishedAt ? article.publishedAt|date('Y-m-d') : article.createdAt|date('Y-m-d') }}</lastmod>
        <priority>0.7</priority>
    </url>
    {% endfor %}
</urlset>
