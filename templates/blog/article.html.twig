{% extends 'base.html.twig' %}

{% set readingTime = (article.content|striptags|split(' ')|length / 250)|round(0, 'ceil') %}
{% set wordCount = article.content|striptags|split(' ')|length %}
{% set domain = app.request.host %}

{% block ticker %}
{% if tickerArticles is defined and tickerArticles|length > 0 %}
<div class="ticker-wrap">
    <div class="ticker">
        {% for i in 0..1 %}
        {% for a in tickerArticles %}
        <span class="ticker-item">
            <i class="bi bi-lightning-fill"></i>
            <a href="{{ path('app_article', {slug: a.slug}) }}">{{ a.title }}</a>
        </span>
        {% endfor %}
        {% endfor %}
    </div>
</div>
{% endif %}
{% endblock %}

{% block title %}{{ article.metaTitle ?? article.title }}{% endblock %}
{% block meta %}
<meta name="description" content="{{ article.metaDescription ?? article.excerpt }}">
<link rel="canonical" href="https://{{ domain }}/{{ article.slug }}">
<meta property="og:url" content="https://{{ domain }}/{{ article.slug }}">
<meta property="og:type" content="article">
<meta property="og:title" content="{{ article.metaTitle ?? article.title }}">
<meta property="og:description" content="{{ article.metaDescription ?? article.excerpt }}">
<meta property="og:site_name" content="{{ domain }}">
<meta property="article:published_time" content="{{ article.publishedAt ? article.publishedAt|date('c') : article.createdAt|date('c') }}">
{% if article.tags %}{% for tag in article.tags %}<meta property="article:tag" content="{{ tag }}">
{% endfor %}{% endif %}
{% if article.imageUrl is defined and article.imageUrl %}
<meta property="og:image" content="{{ article.imageUrl }}">
<meta name="twitter:image" content="{{ article.imageUrl }}">
{% endif %}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ article.metaTitle ?? article.title }}">
<meta name="twitter:description" content="{{ article.metaDescription ?? article.excerpt }}">
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{{ article.title|e('js') }}",
    "description": "{{ (article.metaDescription ?? article.excerpt)|e('js') }}",
    "datePublished": "{{ article.publishedAt ? article.publishedAt|date('c') : article.createdAt|date('c') }}",
    "dateModified": "{{ article.deployedAt ? article.deployedAt|date('c') : article.createdAt|date('c') }}",
    "wordCount": {{ wordCount }},
    "author": {"@type": "Organization", "name": "{{ domain }}", "url": "https://{{ domain }}"},
    "publisher": {"@type": "Organization", "name": "{{ domain }}", "url": "https://{{ domain }}"},
    "mainEntityOfPage": {"@type": "WebPage", "@id": "https://{{ domain }}/{{ article.slug }}"},
    "articleSection": "{{ article.category == 'evergreen' ? 'Guides' : 'Actualités' }}"
    {% if article.keyword %}, "keywords": "{{ article.keyword|e('js') }}"{% endif %}
}
</script>
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://{{ domain }}/"},
        {"@type": "ListItem", "position": 2, "name": "{{ article.category == 'evergreen' ? 'Guides' : 'Actualités' }}", "item": "https://{{ domain }}/{{ article.category == 'evergreen' ? 'guides' : 'actualites' }}"},
        {"@type": "ListItem", "position": 3, "name": "{{ article.title|e('js') }}"}
    ]
}
</script>
{% endblock %}

{% block progress %}
<div class="reading-progress" id="readingProgress"></div>
{% endblock %}

{% block body_wrapper %}
<div class="article-wrapper">
    <!-- TOC Sidebar (left, like Ringover) -->
    <aside class="article-sidebar" style="order:-1;">
        <div class="toc-sticky">
            <div class="toc-box" id="articleSummary">
                <div class="toc-title"><i class="bi bi-list-nested"></i> Sommaire</div>
                <ul class="toc-list" id="tocList"></ul>
            </div>
            <div class="info-box mt-3">
                <div><i class="bi bi-clock me-1"></i><strong>{{ readingTime }} min</strong> de lecture</div>
            </div>
        </div>
    </aside>

    <!-- Article main content -->
    <article class="article-main" id="article">
        <!-- Breadcrumb -->
        <div class="breadcrumb">
            <a href="{{ path('app_home') }}">Accueil</a>
            <span class="breadcrumb-separator">/</span>
            <a href="{{ path(article.category == 'evergreen' ? 'app_category_evergreen' : 'app_category_actualites') }}">
                {{ article.category == 'evergreen' ? 'Guides' : 'Actualités' }}
            </a>
            <span class="breadcrumb-separator">/</span>
            <span style="color:var(--text-light);">{{ article.title|length > 50 ? article.title[:50] ~ '...' : article.title }}</span>
        </div>

        <!-- Article header -->
        <div class="article-header">
            <span class="category-pill">{{ article.category == 'evergreen' ? 'Guide' : 'Actualité' }}</span>
            <h1>{{ article.title }}</h1>
            {% if article.excerpt %}
            <p style="color:var(--text-light); font-size:1.05rem; line-height:1.6; margin-bottom:1rem;">{{ article.excerpt }}</p>
            {% endif %}
            <div class="article-meta">
                <span><i class="bi bi-calendar3 me-1"></i>{{ article.publishedAt ? article.publishedAt|date('d/m/Y') : article.createdAt|date('d/m/Y') }}</span>
                <span><i class="bi bi-clock me-1"></i>{{ readingTime }} min de lecture</span>
                {% if article.keyword %}
                <span><i class="bi bi-key me-1"></i>{{ article.keyword }}</span>
                {% endif %}
            </div>
            {% if event is defined and event %}
            <div class="mt-2">
                {% if event.city %}
                <a href="{{ path('app_city', {city: event.city}) }}" class="badge text-decoration-none" style="background:var(--primary); color:#fff; font-size:.75rem;">
                    <i class="bi bi-geo-alt-fill me-1"></i>{{ event.city }}
                </a>
                {% endif %}
                <a href="{{ path('app_type', {eventType: event.eventType}) }}" class="badge text-decoration-none" style="background:var(--accent); color:#fff; font-size:.75rem;">
                    <i class="bi bi-tag-fill me-1"></i>{{ event.eventType }}
                </a>
            </div>
            {% endif %}
        </div>

        {% if article.imageUrl is defined and article.imageUrl %}
        <figure style="margin:0 0 2rem 0;">
            <img src="{{ article.imageUrl }}" alt="{{ article.imageAlt ?? article.title }}" loading="eager"
                 class="article-hero-img">
            {% if article.imageAlt %}
            <figcaption style="text-align:center; font-size:.72rem; color:var(--text-light); margin-top:.4rem; font-style:italic;">{{ article.imageAlt }}</figcaption>
            {% endif %}
        </figure>
        {% endif %}

        <!-- Article content -->
        <div class="article-content article_text" id="articleContent">
            {{ article.content|raw }}
        </div>

        <!-- Sources -->
        {% if article.sources and article.sources|length > 0 %}
        <div class="sources-box">
            <h3><i class="bi bi-journal-bookmark me-1"></i>Sources et références</h3>
            <ol>
                {% for source in article.sources %}
                <li>
                    {% if source.url is defined %}
                        <a href="{{ source.url }}" target="_blank" rel="noopener nofollow">{{ source.titre ?? 'Source' }}</a>
                    {% else %}
                        {{ source.titre ?? source }}
                    {% endif %}
                </li>
                {% endfor %}
            </ol>
        </div>
        {% endif %}

        <!-- Tags -->
        {% if article.tags and article.tags|length > 0 %}
        <div class="tags-list">
            {% for tag in article.tags %}
            <span class="tag-badge">{{ tag }}</span>
            {% endfor %}
        </div>
        {% endif %}

        <!-- CTA -->
        <div class="article-cta">
            <h3>Cet article vous a été utile ?</h3>
            <p>Découvrez nos autres guides et analyses.</p>
            <a href="{{ path('app_home') }}" class="btn"><i class="bi bi-grid me-1"></i>Tous les articles</a>
        </div>
    </article>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', () => {
    const content = document.getElementById('articleContent');
    const tocList = document.getElementById('tocList');
    const headings = content.querySelectorAll('h2');

    // Build TOC
    headings.forEach((h, i) => {
        const id = 'title-' + (i + 1);
        h.id = id;
        h.dataset.id = i + 1;
        const li = document.createElement('li');
        li.className = 'summary_link';
        li.dataset.id = i + 1;
        li.innerHTML = `<a href="#${id}">${h.textContent}</a>`;
        tocList.appendChild(li);
    });

    // Hide TOC if no headings
    if (headings.length === 0) {
        document.getElementById('articleSummary').style.display = 'none';
    }

    // Highlight active TOC on scroll (IntersectionObserver like Ringover)
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                tocList.querySelectorAll('a').forEach(a => a.classList.remove('highlight'));
                const active = tocList.querySelector(`li[data-id="${entry.target.dataset.id}"] a`);
                if (active) active.classList.add('highlight');
            }
        });
    }, { rootMargin: '-80px 0px -70% 0px', threshold: 0 });

    headings.forEach(h => observer.observe(h));

    // TOC click smooth scroll with offset
    tocList.addEventListener('click', e => {
        if (e.target.tagName === 'A') {
            e.preventDefault();
            const target = document.querySelector(e.target.getAttribute('href'));
            if (target) {
                window.scrollTo({ top: target.offsetTop - 100, behavior: 'smooth' });
            }
        }
    });

    // Reading progress bar
    const progressBar = document.getElementById('readingProgress');
    const article = document.getElementById('article');
    window.addEventListener('scroll', () => {
        const rect = article.getBoundingClientRect();
        const total = article.offsetHeight - window.innerHeight;
        const scrolled = Math.max(0, -rect.top);
        progressBar.style.width = Math.min(100, (scrolled / total) * 100) + '%';
    }, { passive: true });

    // Auto-detect FAQ sections and build schema
    headings.forEach(h => {
        if (h.textContent.toLowerCase().includes('faq')) {
            const questions = [];
            let pointer = h.nextElementSibling;
            let idx = 0;
            while (pointer && (pointer.tagName === 'H3' || pointer.tagName === 'P' || pointer.tagName === 'OL' || pointer.tagName === 'UL')) {
                if (pointer.tagName === 'H3') {
                    questions.push({ question: pointer.textContent, response: [] });
                    let next = pointer.nextElementSibling;
                    while (next && (next.tagName === 'P' || next.tagName === 'OL' || next.tagName === 'UL')) {
                        questions[questions.length - 1].response.push(next.textContent);
                        next = next.nextElementSibling;
                    }
                    pointer = next;
                } else {
                    pointer = pointer.nextElementSibling;
                }
            }
            if (questions.length > 0) {
                const script = document.createElement('script');
                script.type = 'application/ld+json';
                script.textContent = JSON.stringify({
                    '@context': 'https://schema.org',
                    '@type': 'FAQPage',
                    mainEntity: questions.map(q => ({
                        '@type': 'Question',
                        name: q.question,
                        acceptedAnswer: { '@type': 'Answer', text: q.response.join(' ') }
                    }))
                });
                document.head.appendChild(script);
            }
        }
    });
});
</script>
{% endblock %}
