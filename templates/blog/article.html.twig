{% extends 'base.html.twig' %}

{% set readingTime = (article.content|striptags|split(' ')|length / 250)|round(0, 'ceil') %}
{% set wordCount = article.content|striptags|split(' ')|length %}
{% set domain = app.request.host %}
{% set isGuide = article.category == 'evergreen' %}

{% block ticker %}
{% if tickerArticles is defined and tickerArticles|length > 0 %}
<div class="ticker-wrap">
    <div class="ticker">
        {% for i in 0..1 %}
        {% for a in tickerArticles %}
        <span class="ticker-item">
            <i class="bi bi-lightning-fill"></i>
            <a href="{{ path('app_article', {slug: a.slug}) }}">{{ a.title }}</a>
        </span>
        {% endfor %}
        {% endfor %}
    </div>
</div>
{% endif %}
{% endblock %}

{% block title %}{{ article.metaTitle ?? article.title }}{% endblock %}
{% block meta %}
{# Préférence images: og_image_url (presse AFP/Reuters) > image_url (générée IA) #}
{% set ogImg = article.ogImageUrl ?: (article.imageUrl ? 'https://' ~ domain ~ article.imageUrl : null) %}
{% set ogImgWidth = article.ogImageWidth ?: 1200 %}
{% set ogImgHeight = article.ogImageHeight ?: 630 %}
{% set articleCity = article.city %}
{% set siteName = articleCity ? 'Actualités ' ~ articleCity ~ ' - ' ~ domain : domain %}

<meta name="description" content="{{ article.metaDescription ?? article.excerpt }}">
<meta name="author" content="{{ article.authorName ?: 'Rédaction ' ~ domain }}">
<meta name="robots" content="index, follow, max-image-preview:large">
<link rel="canonical" href="https://{{ domain }}/{{ article.slug }}">

{# Open Graph — partages sociaux (Facebook, LinkedIn, WhatsApp, Slack, Discord) #}
<meta property="og:locale" content="fr_FR">
<meta property="og:url" content="https://{{ domain }}/{{ article.slug }}">
<meta property="og:type" content="article">
<meta property="og:title" content="{{ article.metaTitle ?? article.title }}">
<meta property="og:description" content="{{ article.metaDescription ?? article.excerpt }}">
<meta property="og:site_name" content="{{ siteName }}">
{% if ogImg %}
<meta property="og:image" content="{{ ogImg }}">
<meta property="og:image:secure_url" content="{{ ogImg }}">
<meta property="og:image:width" content="{{ ogImgWidth }}">
<meta property="og:image:height" content="{{ ogImgHeight }}">
<meta property="og:image:alt" content="{{ article.imageAlt ?: article.title }}">
{% endif %}
<meta property="article:published_time" content="{{ article.publishedAt ? article.publishedAt|date('c') : article.createdAt|date('c') }}">
<meta property="article:modified_time" content="{{ article.deployedAt ? article.deployedAt|date('c') : article.createdAt|date('c') }}">
<meta property="article:section" content="{{ isGuide ? 'Guides' : 'Actualités' }}">
<meta property="article:author" content="{{ article.authorName ?: 'Rédaction ' ~ domain }}">
{% if article.tags %}{% for tag in article.tags %}<meta property="article:tag" content="{{ tag }}">
{% endfor %}{% endif %}

{# Twitter / X Card #}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ article.metaTitle ?? article.title }}">
<meta name="twitter:description" content="{{ article.metaDescription ?? article.excerpt }}">
{% if ogImg %}<meta name="twitter:image" content="{{ ogImg }}">{% endif %}
{% if ogImg %}<meta name="twitter:image:alt" content="{{ article.imageAlt ?: article.title }}">{% endif %}

{# Geo tags (quand la ville OSINT est connue) #}
{% if article.latitude and article.longitude %}
<meta name="geo.region" content="FR">
<meta name="geo.placename" content="{{ articleCity }}">
<meta name="geo.position" content="{{ article.latitude }};{{ article.longitude }}">
<meta name="ICBM" content="{{ article.latitude }}, {{ article.longitude }}">
{% endif %}

{# JSON-LD: NewsArticle pour les actualités (boost Google News), Article pour les guides #}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "{{ isGuide ? 'Article' : 'NewsArticle' }}",
    "headline": {{ article.title|json_encode|raw }},
    "description": {{ (article.metaDescription ?? article.excerpt)|json_encode|raw }},
    "datePublished": "{{ article.publishedAt ? article.publishedAt|date('c') : article.createdAt|date('c') }}",
    "dateModified": "{{ article.deployedAt ? article.deployedAt|date('c') : article.createdAt|date('c') }}",
    "wordCount": {{ wordCount }},
    {% if ogImg %}"image": {
        "@type": "ImageObject",
        "url": {{ ogImg|json_encode|raw }},
        "width": {{ ogImgWidth }},
        "height": {{ ogImgHeight }}
    },{% endif %}
    "author": {
        "@type": "Organization",
        "name": {{ (article.authorName ?: 'Rédaction ' ~ domain)|json_encode|raw }},
        "url": "https://{{ domain }}"
    },
    "publisher": {
        "@type": "Organization",
        "name": {{ domain|json_encode|raw }},
        "url": "https://{{ domain }}",
        "logo": {
            "@type": "ImageObject",
            "url": "https://{{ domain }}/favicon.ico"
        }
    },
    "mainEntityOfPage": {"@type": "WebPage", "@id": "https://{{ domain }}/{{ article.slug }}"},
    "articleSection": "{{ isGuide ? 'Guides' : 'Actualités' }}",
    "inLanguage": "fr-FR"
    {% if article.keyword %}, "keywords": {{ article.keyword|json_encode|raw }}{% endif %}
    {% if articleCity %}, "contentLocation": {
        "@type": "Place",
        "name": {{ articleCity|json_encode|raw }}
        {% if article.latitude and article.longitude %}, "geo": {
            "@type": "GeoCoordinates",
            "latitude": {{ article.latitude }},
            "longitude": {{ article.longitude }}
        }{% endif %}
    }{% endif %}
    {% if article.videoUrl and article.videoThumbnail %}, "video": {
        "@type": "VideoObject",
        "name": {{ article.title|json_encode|raw }},
        "description": {{ (article.metaDescription ?? article.excerpt)|json_encode|raw }},
        "thumbnailUrl": {{ article.videoThumbnail|json_encode|raw }},
        "uploadDate": "{{ article.publishedAt ? article.publishedAt|date('c') : article.createdAt|date('c') }}",
        "contentUrl": {{ article.videoUrl|json_encode|raw }},
        "embedUrl": {{ article.videoUrl|replace({'watch?v=': 'embed/'})|json_encode|raw }}
    }{% endif %}
}
</script>

{# BreadcrumbList avec ville si disponible #}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://{{ domain }}/"},
        {"@type": "ListItem", "position": 2, "name": "{{ isGuide ? 'Guides' : 'Actualités' }}", "item": "https://{{ domain }}/{{ isGuide ? 'guides' : 'actualites' }}"}
        {% if articleCity %}, {"@type": "ListItem", "position": 3, "name": {{ articleCity|json_encode|raw }}, "item": "https://{{ domain }}/ville/{{ articleCity|lower|replace({' ': '-'}) }}"}{% endif %}
        , {"@type": "ListItem", "position": {{ articleCity ? 4 : 3 }}, "name": {{ article.title|json_encode|raw }}}
    ]
}
</script>
{% endblock %}

{% block progress %}
<div class="reading-progress" id="readingProgress"></div>
{% endblock %}

{% block body_wrapper %}
{% if isGuide %}
{# ===== GUIDE: sidebar TOC + full layout ===== #}
<div class="article-wrapper">
    <aside class="article-sidebar" style="order:-1;">
        <div class="toc-sticky">
            <div class="toc-box" id="articleSummary">
                <div class="toc-title"><i class="bi bi-list-nested"></i> Sommaire</div>
                <ul class="toc-list" id="tocList"></ul>
            </div>
            <div class="info-box mt-3">
                <div><i class="bi bi-clock me-1"></i><strong>{{ readingTime }} min</strong> de lecture</div>
            </div>
        </div>
    </aside>

    <article class="article-main" id="article">
        <div class="breadcrumb">
            <a href="{{ path('app_home') }}">Accueil</a>
            <span class="breadcrumb-separator">/</span>
            <a href="{{ path('app_category_evergreen') }}">Guides</a>
            <span class="breadcrumb-separator">/</span>
            <span style="color:var(--text-light);">{{ article.title|length > 50 ? article.title[:50] ~ '...' : article.title }}</span>
        </div>

        <div class="article-header">
            <span class="category-pill" style="background:#27ae60;">Guide</span>
            <h1>{{ article.title }}</h1>
            {% if article.excerpt %}
            <p style="color:var(--text-light); font-size:1.05rem; line-height:1.6; margin-bottom:1rem;">{{ article.excerpt }}</p>
            {% endif %}
            <div class="article-meta">
                <span><i class="bi bi-calendar3 me-1"></i>{{ article.publishedAt ? article.publishedAt|date('d/m/Y') : article.createdAt|date('d/m/Y') }}</span>
                <span><i class="bi bi-clock me-1"></i>{{ readingTime }} min de lecture</span>
                {% if article.keyword %}
                <span><i class="bi bi-tag me-1"></i>{{ article.keyword }}</span>
                {% endif %}
            </div>
        </div>

        {% if article.imageUrl is defined and article.imageUrl %}
        <figure style="margin:0 0 2rem 0;">
            <img src="{{ article.imageUrl }}" alt="{{ article.imageAlt ?? article.title }}" loading="eager" class="article-hero-img">
        </figure>
        {% endif %}

        <div class="article-content article_text" id="articleContent">
            {{ article.content|raw }}
        </div>

        {% if article.videoEmbedCode %}
        <div class="article-video" style="margin:1.5rem 0;">
            <div style="font-size:.9rem;color:var(--text);margin-bottom:.6rem;line-height:1.45;">
                <i class="bi bi-play-circle-fill me-1" style="color:var(--accent);"></i>
                {% if article.videoIntro %}{{ article.videoIntro }}{% else %}<strong>Vidéo liée</strong>{% endif %}
                {% if article.videoTitle %} :
                    <a href="{{ article.videoUrl }}" target="_blank" rel="noopener" style="color:var(--text-dark); text-decoration:none; font-weight:600;">
                        « {{ article.videoTitle }} »
                    </a>{% if article.videoChannel %} <span style="color:#9ca3af;font-size:.85rem;">— {{ article.videoChannel }}</span>{% endif %}
                {% endif %}
            </div>
            {{ article.videoEmbedCode|raw }}
        </div>
        {% endif %}

        {% if article.sources and article.sources|length > 0 %}
        <div class="sources-box">
            <h3><i class="bi bi-journal-bookmark me-1"></i>Sources et références</h3>
            <ol>
                {% for source in article.sources %}
                <li>{% if source.url is defined %}<a href="{{ source.url }}" target="_blank" rel="noopener nofollow">{{ source.titre ?? 'Source' }}</a>{% else %}{{ source.titre ?? source }}{% endif %}</li>
                {% endfor %}
            </ol>
        </div>
        {% endif %}

        {% if article.tags and article.tags|length > 0 %}
        <div class="tags-list">
            {% for tag in article.tags %}<span class="tag-badge">{{ tag }}</span>{% endfor %}
        </div>
        {% endif %}

        {# Widget désactivé — doublons et articles similaires non pertinents #}
        {% if false and articleCity is defined and articleCity and relatedCity is defined and relatedCity|length > 0 %}
        <div style="margin-top:2rem; padding:1.5rem; background:var(--bg-alt); border-radius:8px;">
            <h3 style="font-size:1.1rem; margin-bottom:1rem;">
                <i class="bi bi-geo-alt-fill me-1" style="color:var(--accent);"></i>
                Autres articles à {{ articleCity }}
            </h3>
            <div class="row g-3">
                {% for r in relatedCity %}
                <div class="col-md-6">
                    <a href="/{{ r.slug }}" class="text-decoration-none" style="color:var(--text-dark); display:block; padding:.5rem 0; border-bottom:1px dotted var(--border);">
                        <strong style="font-size:.9rem; line-height:1.35;">{{ r.title|length > 80 ? r.title[:80] ~ '...' : r.title }}</strong>
                        {% if r.published_at %}<div style="font-size:.7rem; color:var(--text-light); margin-top:.2rem;">{{ r.published_at|date('d/m/Y') }}</div>{% endif %}
                    </a>
                </div>
                {% endfor %}
            </div>
            <a href="{{ path('app_city', {city: articleCity}) }}" style="margin-top:.8rem; display:inline-block; color:var(--accent); text-decoration:none; font-size:.85rem;">
                Toutes les actualités à {{ articleCity }} →
            </a>
        </div>
        {% endif %}

        <div class="article-cta">
            <h3>Cet article vous a été utile ?</h3>
            <p>Découvrez nos autres guides et analyses.</p>
            <a href="{{ path('app_home') }}" class="btn"><i class="bi bi-grid me-1"></i>Tous les articles</a>
        </div>
    </article>
</div>

{% else %}
{# ===== ACTUALITÉ: centered, clean, Le Parisien style ===== #}
<div style="max-width:780px; margin:0 auto; padding:2rem 1.5rem;">
    <article id="article">
        <div class="breadcrumb">
            <a href="{{ path('app_home') }}">Accueil</a>
            <span class="breadcrumb-separator">/</span>
            <a href="{{ path('app_category_actualites') }}">Actualités</a>
        </div>

        <div style="color:var(--accent); font-weight:700; font-size:.9rem; margin-bottom:.5rem;">
            {% if event is defined and event %}
                <a href="{{ path('app_type', {eventType: event.eventType}) }}" style="color:var(--accent);">{{ event.eventType|capitalize }}</a>
            {% else %}
                Actualité
            {% endif %}
        </div>

        <h1 style="font-size:2rem; font-weight:800; color:var(--text-dark); line-height:1.25; margin-bottom:1rem;">{{ article.title }}</h1>

        {% if article.excerpt %}
        <p style="font-size:1.15rem; color:var(--text); line-height:1.6; margin-bottom:1rem;">{{ article.excerpt }}</p>
        {% endif %}

        <div style="font-size:.82rem; color:var(--text-light); margin-bottom:1.5rem;">
            Par {{ domain }}
            <span style="display:block; color:var(--accent); margin-top:.2rem;">Le {{ article.publishedAt ? article.publishedAt|date('d/m/Y') : article.createdAt|date('d/m/Y') }} · {{ readingTime }} min de lecture</span>
        </div>

        {% if event is defined and event %}
        <div style="margin-bottom:1.5rem;">
            {% if event.city %}
            <a href="{{ path('app_city', {city: event.city}) }}" class="badge text-decoration-none" style="background:var(--bg-alt); color:var(--text-dark); font-size:.78rem; border:1px solid var(--border);">
                <i class="bi bi-geo-alt-fill me-1" style="color:var(--accent);"></i>{{ event.city }}
            </a>
            {% endif %}
            <a href="{{ path('app_type', {eventType: event.eventType}) }}" class="badge text-decoration-none" style="background:var(--bg-alt); color:var(--text-dark); font-size:.78rem; border:1px solid var(--border);">
                <i class="bi bi-tag-fill me-1" style="color:var(--accent);"></i>{{ event.eventType }}
            </a>
        </div>
        {% endif %}

        {% if article.imageUrl is defined and article.imageUrl %}
        <figure style="margin:0 0 2rem 0;">
            <img src="{{ article.imageUrl }}" alt="{{ article.imageAlt ?? article.title }}" loading="eager"
                 style="width:100%; max-height:480px; object-fit:cover;">
            {% if article.imageAlt %}
            <figcaption style="font-size:.72rem; color:var(--text-light); margin-top:.4rem; font-style:italic;">{{ article.imageAlt }}</figcaption>
            {% endif %}
        </figure>
        {% endif %}

        <div class="article-content" id="articleContent">
            {{ article.content|raw }}
        </div>

        {% if article.videoEmbedCode %}
        <div class="article-video" style="margin:1.5rem 0;">
            <div style="font-size:.9rem;color:var(--text);margin-bottom:.6rem;line-height:1.45;">
                <i class="bi bi-play-circle-fill me-1" style="color:var(--accent);"></i>
                {% if article.videoIntro %}{{ article.videoIntro }}{% else %}<strong>Vidéo liée</strong>{% endif %}
                {% if article.videoTitle %} :
                    <a href="{{ article.videoUrl }}" target="_blank" rel="noopener" style="color:var(--text-dark); text-decoration:none; font-weight:600;">
                        « {{ article.videoTitle }} »
                    </a>{% if article.videoChannel %} <span style="color:#9ca3af;font-size:.85rem;">— {{ article.videoChannel }}</span>{% endif %}
                {% endif %}
            </div>
            {{ article.videoEmbedCode|raw }}
        </div>
        {% endif %}

        {% if article.tags and article.tags|length > 0 %}
        <div class="tags-list" style="margin-top:2rem; padding-top:1.5rem; border-top:1px solid var(--border);">
            {% for tag in article.tags %}<span class="tag-badge">{{ tag }}</span>{% endfor %}
        </div>
        {% endif %}

        {# Widget: autres actus dans la même ville (SEO local) #}
        {% if articleCity is defined and articleCity and relatedCity is defined and relatedCity|length > 0 %}
        <div style="margin-top:2rem; padding:1.5rem; background:var(--bg-alt); border-radius:8px;">
            <h3 style="font-size:1.1rem; margin-bottom:1rem;">
                <i class="bi bi-geo-alt-fill me-1" style="color:var(--accent);"></i>
                Autres actualités à {{ articleCity }}
            </h3>
            <div class="row g-3">
                {% for r in relatedCity %}
                <div class="col-md-6">
                    <a href="/{{ r.slug }}" class="text-decoration-none" style="color:var(--text-dark); display:block; padding:.5rem 0; border-bottom:1px dotted var(--border);">
                        <strong style="font-size:.9rem; line-height:1.35;">{{ r.title|length > 80 ? r.title[:80] ~ '...' : r.title }}</strong>
                        {% if r.published_at %}<div style="font-size:.7rem; color:var(--text-light); margin-top:.2rem;">{{ r.published_at|date('d/m/Y') }}</div>{% endif %}
                    </a>
                </div>
                {% endfor %}
            </div>
            <a href="{{ path('app_city', {city: articleCity}) }}" style="margin-top:.8rem; display:inline-block; color:var(--accent); text-decoration:none; font-size:.85rem;">
                Toutes les actualités à {{ articleCity }} →
            </a>
        </div>
        {% endif %}
    </article>
</div>
{% endif %}
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', () => {
    const content = document.getElementById('articleContent');
    const headings = content.querySelectorAll('h2');
    {% if isGuide %}
    const tocList = document.getElementById('tocList');

    headings.forEach((h, i) => {
        const id = 'title-' + (i + 1);
        h.id = id;
        h.dataset.id = i + 1;
        const li = document.createElement('li');
        li.className = 'summary_link';
        li.dataset.id = i + 1;
        li.innerHTML = `<a href="#${id}">${h.textContent}</a>`;
        tocList.appendChild(li);
    });

    if (headings.length === 0) {
        document.getElementById('articleSummary').style.display = 'none';
    }

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                tocList.querySelectorAll('a').forEach(a => a.classList.remove('highlight'));
                const active = tocList.querySelector(`li[data-id="${entry.target.dataset.id}"] a`);
                if (active) active.classList.add('highlight');
            }
        });
    }, { rootMargin: '-80px 0px -70% 0px', threshold: 0 });

    headings.forEach(h => observer.observe(h));

    tocList.addEventListener('click', e => {
        if (e.target.tagName === 'A') {
            e.preventDefault();
            const target = document.querySelector(e.target.getAttribute('href'));
            if (target) window.scrollTo({ top: target.offsetTop - 100, behavior: 'smooth' });
        }
    });
    {% endif %}

    // Reading progress bar
    const progressBar = document.getElementById('readingProgress');
    const article = document.getElementById('article');
    window.addEventListener('scroll', () => {
        const rect = article.getBoundingClientRect();
        const total = article.offsetHeight - window.innerHeight;
        const scrolled = Math.max(0, -rect.top);
        progressBar.style.width = Math.min(100, (scrolled / total) * 100) + '%';
    }, { passive: true });

    // FAQ schema detection
    headings.forEach(h => {
        if (h.textContent.toLowerCase().includes('faq')) {
            const questions = [];
            let pointer = h.nextElementSibling;
            while (pointer && (pointer.tagName === 'H3' || pointer.tagName === 'P' || pointer.tagName === 'OL' || pointer.tagName === 'UL')) {
                if (pointer.tagName === 'H3') {
                    questions.push({ question: pointer.textContent, response: [] });
                    let next = pointer.nextElementSibling;
                    while (next && (next.tagName === 'P' || next.tagName === 'OL' || next.tagName === 'UL')) {
                        questions[questions.length - 1].response.push(next.textContent);
                        next = next.nextElementSibling;
                    }
                    pointer = next;
                } else {
                    pointer = pointer.nextElementSibling;
                }
            }
            if (questions.length > 0) {
                const script = document.createElement('script');
                script.type = 'application/ld+json';
                script.textContent = JSON.stringify({
                    '@context': 'https://schema.org', '@type': 'FAQPage',
                    mainEntity: questions.map(q => ({
                        '@type': 'Question', name: q.question,
                        acceptedAnswer: { '@type': 'Answer', text: q.response.join(' ') }
                    }))
                });
                document.head.appendChild(script);
            }
        }
    });
});
</script>
{% endblock %}
