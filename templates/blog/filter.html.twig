{% extends 'base.html.twig' %}

{% set isCity = filterType == 'ville' %}
{% set domain = app.request.host %}

{% block title %}
    {% if isCity %}Actualités à {{ filterValue }} — {{ domain }}
    {% else %}{{ filterValue|capitalize }} — {{ domain }}{% endif %}
{% endblock %}

{% block meta %}
<meta name="description" content="{% if isCity %}Toutes les actualités à {{ filterValue }} sur {{ domain }}.{% else %}Articles {{ filterValue }} sur {{ domain }}.{% endif %}">
<link rel="canonical" href="https://{{ domain }}/{% if isCity %}ville/{{ filterValue|lower|replace({' ': '-'}) }}{% else %}type/{{ filterSlug }}{% endif %}">
{% endblock %}

{% block body %}
{# ===== H1 — Euronews tag page style: bold, clean, border-bottom ===== #}
<h1 style="font-size:2rem; font-weight:700; color:var(--text-dark); margin-bottom:1rem; padding-bottom:1rem; border-bottom:3px solid var(--text-dark);">
    {% if isCity %}Actualités à {{ filterValue }}{% else %}{{ filterValue }}{% endif %}
</h1>

{% if articles is empty %}
<p style="color:var(--text-light); font-size:1.1rem; margin-top:2rem;">Aucun article pour cette catégorie.</p>
{% else %}

{# ===== FEATURED — Euronews tag layout: big image left + sidebar articles right ===== #}
{% set featured = articles|first %}
<div style="display:flex; gap:2rem; margin-bottom:2.5rem; border-bottom:1px solid var(--border); padding-bottom:2rem;">
    {# Left: featured article with large image #}
    <div style="flex:0 0 55%;">
        {% if featured.image_url is defined and featured.image_url %}
        <a href="/{{ featured.slug }}">
            <img src="{{ featured.image_url }}" alt="{{ featured.image_alt ?? featured.title }}" loading="eager"
                 style="width:100%; aspect-ratio:16/9; object-fit:cover; display:block; margin-bottom:1rem;">
        </a>
        {% endif %}
        <span class="category-pill" style="margin-bottom:.5rem; display:inline-block;">{{ filterValue|upper }}</span>
        <h2 style="font-size:1.5rem; font-weight:700; line-height:1.25; margin:.5rem 0;">
            <a href="/{{ featured.slug }}" style="color:var(--text-dark); text-decoration:none;">{{ featured.title }}</a>
        </h2>
        {% if featured.excerpt is defined and featured.excerpt %}
        <p style="color:var(--text); font-size:.9rem; line-height:1.6; margin-top:.5rem;">{{ featured.excerpt|length > 180 ? featured.excerpt[:180] ~ '...' : featured.excerpt }}</p>
        {% endif %}
    </div>

    {# Right: sidebar with 3-4 articles (image + title) #}
    <div style="flex:1;">
        {% for art in articles|slice(1, 4) %}
        <div style="display:flex; gap:1rem; padding:.8rem 0; border-bottom:1px solid var(--border); {% if loop.last %}border-bottom:none;{% endif %}">
            {% if art.image_url is defined and art.image_url %}
            <a href="/{{ art.slug }}" style="flex:0 0 180px;">
                <img src="{{ art.image_url }}" alt="{{ art.image_alt ?? art.title }}" loading="lazy"
                     style="width:180px; height:100px; object-fit:cover; display:block;">
            </a>
            {% endif %}
            <div>
                <span class="category-pill" style="font-size:.7rem; margin-bottom:.3rem; display:inline-block;">{{ filterValue|upper }}</span>
                <h3 style="font-size:.9rem; font-weight:700; line-height:1.3; margin:0;">
                    <a href="/{{ art.slug }}" style="color:var(--text-dark); text-decoration:none;">{{ art.title }}</a>
                </h3>
            </div>
        </div>
        {% endfor %}
    </div>
</div>

{# ===== GRID — remaining articles in 3 columns ===== #}
{% if articles|length > 5 %}
<div class="row g-3">
    {% for art in articles|slice(5) %}
    <div class="col-md-6 col-lg-4">
        <div class="article-card h-100">
            {% if art.image_url is defined and art.image_url %}
            <a href="/{{ art.slug }}">
                <img src="{{ art.image_url }}" alt="{{ art.image_alt ?? art.title }}" loading="lazy">
            </a>
            {% endif %}
            <div class="card-body">
                <span class="category-pill mb-1">{{ filterValue|upper }}</span>
                <h3 class="card-title"><a href="/{{ art.slug }}">{{ art.title }}</a></h3>
                {% if art.excerpt is defined and art.excerpt %}
                <p class="card-text" style="margin-top:.3rem;">{{ art.excerpt|length > 100 ? art.excerpt[:100] ~ '...' : art.excerpt }}</p>
                {% endif %}
                <div style="font-size:.75rem; color:var(--text-light); margin-top:.5rem;">
                    {{ art.published_at ? art.published_at|date('d/m/Y') : '' }}
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}

{% endif %}
{% endblock %}
