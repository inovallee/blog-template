{% extends 'base.html.twig' %}

{% block title %}{{ app.request.host }} — Actualités{% endblock %}
{% block meta %}
<meta name="description" content="Actualités, faits divers et analyses sur {{ app.request.host }}">
<link rel="canonical" href="https://{{ app.request.host }}/">
{% endblock %}

{% block topnav %}
<nav class="topnav d-none d-md-block">
    <div class="topnav-inner">
        <a href="{{ path('app_home') }}" class="active">À la une</a>
        <span class="sep"></span>
        <a href="{{ path('app_category_actualites') }}">En continu</a>
        {% if typeSections is defined and typeSections|length > 0 %}
        <span class="sep"></span>
        {% for section in typeSections %}
        <a href="{{ path('app_type', {eventType: section.type}) }}">{{ section.label }}</a>
        {% endfor %}
        {% endif %}
        <span class="sep"></span>
        <a href="{{ path('app_category_evergreen') }}">Guides</a>
    </div>
</nav>
{% endblock %}

{% block ticker %}
{% set actus = articles|filter(a => a.category == 'actualites') %}
{% if actus|length > 0 %}
<div class="ticker-wrap">
    <div class="ticker">
        {% for i in 0..1 %}
        {% for article in actus %}
        <span class="ticker-item">
            <i class="bi bi-lightning-fill"></i>
            <a href="{{ path('app_article', {slug: article.slug}) }}">{{ article.title }}</a>
        </span>
        {% endfor %}
        {% endfor %}
    </div>
</div>
{% endif %}
{% endblock %}

{% block body %}
{% if articles|length > 0 %}
{% set featured = articles|first %}

{# HERO — big image + title side by side #}
<div class="row g-0 mb-4" style="border-bottom:2px solid var(--primary); padding-bottom:1.5rem;">
    {% if featured.imageUrl %}
    <div class="col-lg-7">
        <a href="{{ path('app_article', {slug: featured.slug}) }}">
            <img src="{{ featured.imageUrl }}" alt="{{ featured.imageAlt ?? featured.title }}" loading="eager"
                 style="width:100%; height:380px; object-fit:cover;">
        </a>
    </div>
    <div class="col-lg-5 ps-lg-4 d-flex flex-column justify-content-center pt-3 pt-lg-0">
    {% else %}
    <div class="col-12">
    {% endif %}
        <span class="category-pill mb-2">{{ featured.category == 'evergreen' ? 'Guide' : 'Actualité' }}</span>
        <h1 style="font-size:1.7rem; font-weight:800; line-height:1.25; margin-bottom:.8rem;">
            <a href="{{ path('app_article', {slug: featured.slug}) }}" class="text-decoration-none" style="color:var(--text-dark);">{{ featured.title }}</a>
        </h1>
        {% if featured.excerpt %}
        <p style="color:var(--text); font-size:.9rem; line-height:1.6;">{{ featured.excerpt|length > 200 ? featured.excerpt[:200] ~ '...' : featured.excerpt }}</p>
        {% endif %}
        <div style="font-size:.78rem; color:var(--text-light);">
            <i class="bi bi-calendar3 me-1"></i>{{ featured.publishedAt ? featured.publishedAt|date('d/m/Y') : '' }}
            <span class="ms-2"><i class="bi bi-clock me-1"></i>{{ (featured.content|striptags|split(' ')|length / 250)|round(0, 'ceil') }} min</span>
        </div>
    </div>
</div>

{# MAIN GRID: Articles + Sidebar "En continu" #}
<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="row g-3">
            {% for article in articles|slice(1, 6) %}
            <div class="col-md-6">
                <div class="article-card h-100">
                    {% if article.imageUrl %}
                    <a href="{{ path('app_article', {slug: article.slug}) }}">
                        <img src="{{ article.imageUrl }}" alt="{{ article.imageAlt ?? article.title }}" loading="lazy">
                    </a>
                    {% endif %}
                    <div class="card-body">
                        <span class="category-pill mb-1" style="font-size:.6rem;">{{ article.category == 'evergreen' ? 'Guide' : 'Actualité' }}</span>
                        <h3 class="card-title"><a href="{{ path('app_article', {slug: article.slug}) }}">{{ article.title }}</a></h3>
                        <div style="font-size:.75rem; color:var(--text-light); margin-top:.5rem;">
                            {{ article.publishedAt ? article.publishedAt|date('d/m/Y') : '' }}
                            · {{ (article.content|striptags|split(' ')|length / 250)|round(0, 'ceil') }} min
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

    <div class="col-lg-4">
        <div class="sidebar-continu">
            <h4>En continu</h4>
            {% for article in articles|slice(1, 12) %}
            <div class="sidebar-item">
                <a href="{{ path('app_article', {slug: article.slug}) }}">{{ article.title }}</a>
                <div class="meta">{{ article.publishedAt ? article.publishedAt|date('d/m/Y') : '' }}</div>
            </div>
            {% endfor %}
        </div>
    </div>
</div>

{# ==== ACTUALITÉS PAR VILLE (SEO localité) ==== #}
{% if citySections is defined and citySections|length > 0 %}
<div class="mb-5">
    <div class="section-header d-flex justify-content-between align-items-center">
        <h2><i class="bi bi-geo-alt-fill me-2" style="color:var(--accent);"></i>Actualités par ville</h2>
        <small><a href="{{ path('app_category_actualites') }}" class="text-decoration-none">Voir toutes les actualités →</a></small>
    </div>
    <div class="row g-4">
        {% for section in citySections %}
        <div class="col-md-6 col-lg-4">
            <div class="city-section" style="border:1px solid var(--border); border-radius:8px; padding:1rem; background:#fff;">
                <h3 style="font-size:1rem; font-weight:700; margin-bottom:.8rem; border-bottom:2px solid var(--accent); padding-bottom:.4rem;">
                    <a href="{{ path('app_city', {city: section.city}) }}" class="text-decoration-none" style="color:var(--text-dark);">
                        <i class="bi bi-geo-alt me-1"></i>{{ section.city }}
                    </a>
                    <small style="font-weight:400; color:var(--text-light); font-size:.75rem;">
                        ({{ section.count }} article{{ section.count > 1 ? 's' : '' }})
                    </small>
                </h3>
                <ul class="list-unstyled mb-2" style="font-size:.85rem;">
                    {% for a in section.articles %}
                    <li style="padding:.35rem 0; border-bottom:1px dotted var(--border);">
                        <a href="{{ path('app_article', {slug: a.slug}) }}" class="text-decoration-none" style="color:var(--text-dark); line-height:1.35; display:inline-block;">
                            {{ a.title|length > 75 ? a.title[:75] ~ '...' : a.title }}
                        </a>
                        {% if a.published_at %}
                        <div style="font-size:.7rem; color:var(--text-light); margin-top:.15rem;">
                            <i class="bi bi-clock"></i> {{ a.published_at|date('d/m/Y') }}
                        </div>
                        {% endif %}
                    </li>
                    {% endfor %}
                </ul>
                <a href="{{ path('app_city', {city: section.city}) }}" style="font-size:.8rem; color:var(--accent); text-decoration:none;">
                    Toutes les actualités à {{ section.city }} →
                </a>
            </div>
        </div>
        {% endfor %}
    </div>
</div>
{% endif %}

{# ALL ARTICLES grid #}
{% if articles|length > 7 %}
<div class="mb-4">
    <div class="section-header">
        <h2>Tous les articles <span style="font-weight:400; font-size:.82rem; color:var(--text-light);">({{ total }})</span></h2>
    </div>
    <div class="row g-3">
        {% for article in articles %}
        {% if not loop.first or page > 1 %}
        <div class="col-md-6 col-lg-4">
            <div class="article-card h-100">
                {% if article.imageUrl %}
                <a href="{{ path('app_article', {slug: article.slug}) }}">
                    <img src="{{ article.imageUrl }}" alt="{{ article.imageAlt ?? article.title }}" loading="lazy">
                </a>
                {% endif %}
                <div class="card-body">
                    <span class="category-pill mb-1" style="font-size:.6rem;">{{ article.category == 'evergreen' ? 'Guide' : 'Actualité' }}</span>
                    <h3 class="card-title"><a href="{{ path('app_article', {slug: article.slug}) }}">{{ article.title }}</a></h3>
                    {% if article.excerpt %}
                    <p class="card-text" style="margin-top:.3rem;">{{ article.excerpt|length > 100 ? article.excerpt[:100] ~ '...' : article.excerpt }}</p>
                    {% endif %}
                    <div style="font-size:.75rem; color:var(--text-light); margin-top:.5rem;">
                        {{ article.publishedAt ? article.publishedAt|date('d/m/Y') : '' }}
                    </div>
                </div>
            </div>
        </div>
        {% endif %}
        {% endfor %}
    </div>
</div>
{% endif %}

{# PAGINATION #}
{% if pages > 1 %}
<nav class="d-flex justify-content-center mt-4 mb-4">
    <ul class="pagination">
        <li class="page-item {{ page <= 1 ? 'disabled' : '' }}">
            <a class="page-link" href="?page={{ page - 1 }}">&laquo;</a>
        </li>
        {% for p in range(max(1, page - 3), min(pages, page + 3)) %}
        <li class="page-item {{ p == page ? 'active' : '' }}">
            <a class="page-link" href="?page={{ p }}">{{ p }}</a>
        </li>
        {% endfor %}
        <li class="page-item {{ page >= pages ? 'disabled' : '' }}">
            <a class="page-link" href="?page={{ page + 1 }}">&raquo;</a>
        </li>
    </ul>
</nav>
{% endif %}

{% endif %}
{% endblock %}
