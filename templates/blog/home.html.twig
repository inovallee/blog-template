{% extends 'base.html.twig' %}

{% block title %}{{ app.request.host }} — Actualités{% endblock %}
{% block meta %}
<meta name="description" content="Actualités, faits divers et analyses sur {{ app.request.host }}">
<link rel="canonical" href="https://{{ app.request.host }}/">
{% endblock %}

{% block ticker %}
{% set actus = articles|filter(a => a.category == 'actualites') %}
{% if actus|length > 0 %}
<div class="ticker-wrap">
    <div class="ticker">
        {% for i in 0..1 %}
        {% for article in actus %}
        <span class="ticker-item">
            <i class="bi bi-lightning-fill"></i>
            <a href="{{ path('app_article', {slug: article.slug}) }}">{{ article.title }}</a>
        </span>
        {% endfor %}
        {% endfor %}
    </div>
</div>
{% endif %}
{% endblock %}

{% block body %}
{# === HERO: Article à la une === #}
{% if articles|length > 0 %}
{% set featured = articles|first %}
<div class="mb-4">
    <div class="row g-0 rounded-3 overflow-hidden" style="background:var(--bg-alt); border:1px solid var(--border);">
        {% if featured.imageUrl %}
        <div class="col-lg-7">
            <a href="{{ path('app_article', {slug: featured.slug}) }}">
                <img src="{{ featured.imageUrl }}" alt="{{ featured.imageAlt ?? featured.title }}" loading="eager"
                     style="width:100%; height:350px; object-fit:cover;">
            </a>
        </div>
        <div class="col-lg-5 p-4 d-flex flex-column justify-content-center">
        {% else %}
        <div class="col-12 p-4">
        {% endif %}
            <span class="category-pill mb-2">{{ featured.category == 'evergreen' ? 'Guide' : 'Actualité' }}</span>
            <h1 style="font-size:1.6rem; font-weight:800; line-height:1.3; margin-bottom:.8rem;">
                <a href="{{ path('app_article', {slug: featured.slug}) }}" class="text-decoration-none" style="color:var(--text-dark);">{{ featured.title }}</a>
            </h1>
            {% if featured.excerpt %}
            <p style="color:var(--text); font-size:.9rem; line-height:1.6;">{{ featured.excerpt|length > 200 ? featured.excerpt[:200] ~ '...' : featured.excerpt }}</p>
            {% endif %}
            <div style="font-size:.78rem; color:var(--text);">
                <i class="bi bi-calendar3 me-1"></i>{{ featured.publishedAt ? featured.publishedAt|date('d/m/Y') : '' }}
                <span class="ms-2"><i class="bi bi-clock me-1"></i>{{ (featured.content|striptags|split(' ')|length / 250)|round(0, 'ceil') }} min</span>
            </div>
        </div>
    </div>
</div>
{% endif %}

{# === SECTION PAR VILLE === #}
{% if citySections|length > 0 %}
<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 style="font-size:1.2rem; font-weight:700; margin:0;"><i class="bi bi-geo-alt-fill me-1" style="color:var(--accent);"></i>Par ville</h2>
    </div>
    <div class="row g-3">
        {% for section in citySections %}
        <div class="col-md-6 col-lg-4">
            <div style="border:1px solid var(--border); border-radius:12px; overflow:hidden;">
                <div style="background:var(--primary); color:#fff; padding:.6rem 1rem; font-weight:600; font-size:.85rem;">
                    <a href="{{ path('app_city', {city: section.city}) }}" class="text-white text-decoration-none">
                        {{ section.city }} <span class="badge bg-light text-dark ms-1">{{ section.count }}</span>
                    </a>
                </div>
                <div style="padding:.8rem 1rem;">
                    {% for art in section.articles[:3] %}
                    <div style="padding:.4rem 0; {{ not loop.last ? 'border-bottom:1px solid var(--border);' : '' }}">
                        <a href="/{{ art.slug }}" class="text-decoration-none" style="color:var(--text-dark); font-size:.82rem; font-weight:500; line-height:1.3; display:block;">
                            {{ art.title|length > 80 ? art.title[:80] ~ '...' : art.title }}
                        </a>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>
{% endif %}

{# === SECTION PAR TYPE === #}
{% if typeSections|length > 0 %}
<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 style="font-size:1.2rem; font-weight:700; margin:0;"><i class="bi bi-tag-fill me-1" style="color:var(--accent);"></i>Par catégorie</h2>
    </div>
    <div class="row g-3">
        {% for section in typeSections %}
        <div class="col-md-6 col-lg-4">
            <div style="border:1px solid var(--border); border-radius:12px; overflow:hidden;">
                <div style="background:var(--accent); color:#fff; padding:.6rem 1rem; font-weight:600; font-size:.85rem;">
                    <a href="{{ path('app_type', {eventType: section.type}) }}" class="text-white text-decoration-none">
                        {{ section.label }} <span class="badge bg-light text-dark ms-1">{{ section.count }}</span>
                    </a>
                </div>
                <div style="padding:.8rem 1rem;">
                    {% for art in section.articles[:3] %}
                    <div style="padding:.4rem 0; {{ not loop.last ? 'border-bottom:1px solid var(--border);' : '' }}">
                        <a href="/{{ art.slug }}" class="text-decoration-none" style="color:var(--text-dark); font-size:.82rem; font-weight:500; line-height:1.3; display:block;">
                            {{ art.title|length > 80 ? art.title[:80] ~ '...' : art.title }}
                        </a>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>
{% endif %}

{# === TOUS LES ARTICLES (grille paginée) === #}
<div class="mb-4">
    <h2 style="font-size:1.2rem; font-weight:700; margin-bottom:1rem;"><i class="bi bi-newspaper me-1" style="color:var(--accent);"></i>Tous les articles <span class="text-muted" style="font-weight:400; font-size:.85rem;">({{ total }})</span></h2>
    <div class="row g-4">
        {% for article in articles %}
        {% if not loop.first or page > 1 %}
        <div class="col-md-6 col-lg-4">
            <div class="article-card h-100">
                {% if article.imageUrl %}
                <a href="{{ path('app_article', {slug: article.slug}) }}">
                    <img src="{{ article.imageUrl }}" alt="{{ article.imageAlt ?? article.title }}" loading="lazy"
                         style="width:100%; height:180px; object-fit:cover;">
                </a>
                {% endif %}
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="category-pill">{{ article.category == 'evergreen' ? 'Guide' : 'Actualité' }}</span>
                        <span class="reading-time"><i class="bi bi-clock me-1"></i>{{ (article.content|striptags|split(' ')|length / 250)|round(0, 'ceil') }} min</span>
                    </div>
                    <h3 class="card-title flex-grow-1">
                        <a href="{{ path('app_article', {slug: article.slug}) }}" class="text-decoration-none" style="color:var(--text-dark);">{{ article.title }}</a>
                    </h3>
                    {% if article.excerpt %}
                    <p class="card-text">{{ article.excerpt|length > 120 ? article.excerpt[:120] ~ '...' : article.excerpt }}</p>
                    {% endif %}
                    <div class="mt-auto d-flex justify-content-between align-items-center">
                        <span class="article-date"><i class="bi bi-calendar3 me-1"></i>{{ article.publishedAt ? article.publishedAt|date('d/m/Y') : '' }}</span>
                        <a href="{{ path('app_article', {slug: article.slug}) }}" class="read-more">Lire <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}
        {% endfor %}
    </div>
</div>

{# === PAGINATION === #}
{% if pages > 1 %}
<nav class="d-flex justify-content-center mt-4 mb-4">
    <ul class="pagination">
        <li class="page-item {{ page <= 1 ? 'disabled' : '' }}">
            <a class="page-link" href="?page={{ page - 1 }}">&laquo;</a>
        </li>
        {% for p in range(max(1, page - 3), min(pages, page + 3)) %}
        <li class="page-item {{ p == page ? 'active' : '' }}">
            <a class="page-link" href="?page={{ p }}">{{ p }}</a>
        </li>
        {% endfor %}
        <li class="page-item {{ page >= pages ? 'disabled' : '' }}">
            <a class="page-link" href="?page={{ page + 1 }}">&raquo;</a>
        </li>
    </ul>
</nav>
{% endif %}
{% endblock %}
