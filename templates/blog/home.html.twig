{% extends 'base.html.twig' %}

{% block title %}{{ app.request.host }} — Actualités{% endblock %}
{% block meta %}
<meta name="description" content="Toute l'actualité sur {{ app.request.host }}. Articles, analyses et guides.">
<link rel="canonical" href="https://{{ app.request.host }}/">
{% endblock %}

{% block ticker %}
{% set actus = articles|filter(a => a.category == 'actualites') %}
{% if actus|length > 0 %}
<div class="ticker-wrap">
    <div class="ticker">
        {% for i in 0..1 %}{% for article in actus %}
        <span class="ticker-item"><i class="bi bi-lightning-fill"></i><a href="{{ path('app_article', {slug: article.slug}) }}">{{ article.title }}</a></span>
        {% endfor %}{% endfor %}
    </div>
</div>
{% endif %}
{% endblock %}

{% block stylesheets %}
<style>
    .lp-hero { position:relative; overflow:hidden; margin-bottom:1.5rem; }
    .lp-hero img { width:100%; height:420px; object-fit:cover; display:block; }
    .lp-hero-overlay { position:absolute; bottom:0; left:0; right:0; padding:2rem 1.5rem 1.5rem; background:linear-gradient(transparent, rgba(0,0,0,.85)); color:#fff; }
    .lp-hero-cat { color:var(--red); font-size:.75rem; font-weight:700; text-transform:uppercase; letter-spacing:.05em; margin-bottom:.4rem; display:inline-block; }
    .lp-hero-title { font-size:2rem; font-weight:700; line-height:1.2; margin:0; }
    .lp-hero-title a { color:#fff; text-decoration:none; }
    .lp-hero-excerpt { font-size:.9rem; margin-top:.5rem; opacity:.85; line-height:1.5; }
    .lp-hero-meta { font-size:.75rem; opacity:.6; margin-top:.4rem; }

    .lp-card { border-bottom:1px solid var(--border); padding-bottom:1rem; margin-bottom:1rem; }
    .lp-card:last-child { border-bottom:none; margin-bottom:0; padding-bottom:0; }
    .lp-card-cat { color:var(--red); font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.03em; margin-bottom:.3rem; display:block; }
    .lp-card-title { font-size:1.05rem; font-weight:700; line-height:1.3; color:var(--text-dark); margin:0; }
    .lp-card-title a { color:var(--text-dark); text-decoration:none; }
    .lp-card-title a:hover { color:var(--accent); }
    .lp-card-meta { font-size:.72rem; color:var(--text-light); margin-top:.3rem; }

    .lp-sidebar-title { font-weight:700; font-size:.9rem; text-transform:uppercase; letter-spacing:.03em; color:var(--text-dark); padding-bottom:.5rem; border-bottom:3px solid var(--red); margin-bottom:1rem; }
    .lp-sidebar-item { padding:.6rem 0; border-bottom:1px solid var(--border); }
    .lp-sidebar-item:last-child { border-bottom:none; }
    .lp-sidebar-item a { color:var(--text-dark); font-size:.85rem; font-weight:600; line-height:1.35; text-decoration:none; display:block; }
    .lp-sidebar-item a:hover { color:var(--accent); }
    .lp-sidebar-item .meta { font-size:.7rem; color:var(--text-light); margin-top:.15rem; }

    @media (max-width: 768px) {
        .lp-hero img { height:260px; }
        .lp-hero-title { font-size:1.4rem; }
        .lp-hero-overlay { padding:1.5rem 1rem 1rem; }
        .lp-card-title { font-size:.95rem; }
    }
    @media (max-width: 576px) {
        .lp-hero img { height:200px; }
        .lp-hero-title { font-size:1.2rem; }
    }
</style>
{% endblock %}

{% block body %}
{% if articles|length > 0 %}
{% set featured = articles|first %}

{# ===== HERO — Le Parisien: full-width image + titre superposé avec gradient ===== #}
<div class="lp-hero">
    {% if featured.imageUrl %}
    <a href="{{ path('app_article', {slug: featured.slug}) }}">
        <img src="{{ featured.imageUrl }}" alt="{{ featured.imageAlt ?? featured.title }}" loading="eager">
    </a>
    {% endif %}
    <div class="lp-hero-overlay">
        <span class="lp-hero-cat">{{ featured.category == 'evergreen' ? 'Guide' : 'Actualité' }}</span>
        <h1 class="lp-hero-title"><a href="{{ path('app_article', {slug: featured.slug}) }}">{{ featured.title }}</a></h1>
        {% if featured.excerpt %}
        <p class="lp-hero-excerpt d-none d-md-block">{{ featured.excerpt|length > 160 ? featured.excerpt[:160] ~ '...' : featured.excerpt }}</p>
        {% endif %}
        <div class="lp-hero-meta">{{ featured.publishedAt ? featured.publishedAt|date('d/m/Y à H:i') : '' }}</div>
    </div>
</div>

{# ===== MAIN GRID — Le Parisien: articles gauche (col-8) + sidebar droite (col-4) ===== #}
<div class="row g-4">
    {# LEFT: articles principaux #}
    <div class="col-lg-8">

        {# 2 cards côte à côte avec images #}
        {% if articles|length > 2 %}
        <div class="row g-3 mb-4">
            {% for article in articles|slice(1, 2) %}
            <div class="col-sm-6">
                <div class="lp-card" style="border-bottom:none; padding-bottom:0;">
                    {% if article.imageUrl %}
                    <a href="{{ path('app_article', {slug: article.slug}) }}">
                        <img src="{{ article.imageUrl }}" alt="{{ article.imageAlt ?? article.title }}" loading="lazy"
                             class="w-100 mb-2" style="aspect-ratio:16/9; object-fit:cover;">
                    </a>
                    {% endif %}
                    <span class="lp-card-cat">{{ article.category == 'evergreen' ? 'Guide' : 'Actualité' }}</span>
                    <h3 class="lp-card-title"><a href="{{ path('app_article', {slug: article.slug}) }}">{{ article.title }}</a></h3>
                    <div class="lp-card-meta">{{ article.publishedAt ? article.publishedAt|date('d/m/Y') : '' }}</div>
                </div>
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {# Liste articles avec thumbnail gauche + titre droite (Le Parisien style) #}
        {% if articles|length > 3 %}
        <div class="border-top pt-3">
            {% for article in articles|slice(3, 6) %}
            <div class="lp-card d-flex gap-3">
                {% if article.imageUrl %}
                <a href="{{ path('app_article', {slug: article.slug}) }}" class="flex-shrink-0">
                    <img src="{{ article.imageUrl }}" alt="{{ article.imageAlt ?? article.title }}" loading="lazy"
                         style="width:180px; height:110px; object-fit:cover;" class="d-none d-sm-block">
                    <img src="{{ article.imageUrl }}" alt="" loading="lazy"
                         style="width:100px; height:70px; object-fit:cover;" class="d-sm-none">
                </a>
                {% endif %}
                <div>
                    <span class="lp-card-cat">{{ article.category == 'evergreen' ? 'Guide' : 'Actualité' }}</span>
                    <h3 class="lp-card-title"><a href="{{ path('app_article', {slug: article.slug}) }}">{{ article.title }}</a></h3>
                    {% if article.excerpt %}
                    <p class="d-none d-md-block" style="font-size:.82rem; color:var(--text-light); margin:.3rem 0 0; line-height:1.4;">{{ article.excerpt|length > 100 ? article.excerpt[:100] ~ '...' : article.excerpt }}</p>
                    {% endif %}
                    <div class="lp-card-meta">{{ article.publishedAt ? article.publishedAt|date('d/m/Y') : '' }}</div>
                </div>
            </div>
            {% endfor %}
        </div>
        {% endif %}
    </div>

    {# RIGHT: sidebar "À lire aussi" #}
    <div class="col-lg-4 d-none d-lg-block">
        <div class="lp-sidebar-title">À lire aussi</div>
        {% for article in articles|slice(1, 10) %}
        <div class="lp-sidebar-item">
            <a href="{{ path('app_article', {slug: article.slug}) }}">{{ article.title|length > 70 ? article.title[:70] ~ '...' : article.title }}</a>
            <div class="meta">{{ article.publishedAt ? article.publishedAt|date('d/m/Y à H:i') : '' }}</div>
        </div>
        {% endfor %}
    </div>
</div>

{# ===== GRILLE ARTICLES RESTANTS — 3 colonnes desktop ===== #}
{% if articles|length > 9 %}
<div class="mt-4 pt-3" style="border-top:3px solid var(--text-dark);">
    <div class="row g-3">
        {% for article in articles|slice(9) %}
        <div class="col-12 col-sm-6 col-lg-4">
            <div class="article-card h-100">
                {% if article.imageUrl %}
                <a href="{{ path('app_article', {slug: article.slug}) }}">
                    <img src="{{ article.imageUrl }}" alt="{{ article.imageAlt ?? article.title }}" loading="lazy">
                </a>
                {% endif %}
                <div class="card-body">
                    <span class="lp-card-cat">{{ article.category == 'evergreen' ? 'Guide' : 'Actualité' }}</span>
                    <h3 class="card-title"><a href="{{ path('app_article', {slug: article.slug}) }}">{{ article.title }}</a></h3>
                    <div class="lp-card-meta">{{ article.publishedAt ? article.publishedAt|date('d/m/Y') : '' }}</div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>
{% endif %}

{# PAGINATION #}
{% if pages > 1 %}
<nav class="d-flex justify-content-center mt-4 mb-4">
    <ul class="pagination">
        <li class="page-item {{ page <= 1 ? 'disabled' : '' }}"><a class="page-link" href="?page={{ page - 1 }}">&laquo;</a></li>
        {% for p in range(max(1, page - 3), min(pages, page + 3)) %}
        <li class="page-item {{ p == page ? 'active' : '' }}"><a class="page-link" href="?page={{ p }}">{{ p }}</a></li>
        {% endfor %}
        <li class="page-item {{ page >= pages ? 'disabled' : '' }}"><a class="page-link" href="?page={{ page + 1 }}">&raquo;</a></li>
    </ul>
</nav>
{% endif %}

{% endif %}
{% endblock %}
