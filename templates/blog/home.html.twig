{% extends 'base.html.twig' %}

{% block title %}{{ app.request.host }} — Actualités{% endblock %}
{% block meta %}
<meta name="description" content="Toute l'actualité sur {{ app.request.host }}. Articles, analyses et guides.">
<link rel="canonical" href="https://{{ app.request.host }}/">
{% endblock %}

{% block ticker %}
{% set actus = articles|filter(a => a.category == 'actualites') %}
{% if actus|length > 0 %}
<div class="ticker-wrap">
    <div class="ticker">
        {% for i in 0..1 %}
        {% for article in actus %}
        <span class="ticker-item">
            <i class="bi bi-lightning-fill"></i>
            <a href="{{ path('app_article', {slug: article.slug}) }}">{{ article.title }}</a>
        </span>
        {% endfor %}
        {% endfor %}
    </div>
</div>
{% endif %}
{% endblock %}

{% block body %}
{% if articles|length > 0 %}
{% set featured = articles|first %}

{# ===== TAGS BAR ===== #}
{% if trendingTags is defined and trendingTags|length > 0 %}
<div class="text-center py-2 border-bottom mb-4">
    {% for tag in trendingTags %}
    <a href="{{ path('app_category_actualites') }}" class="text-decoration-none" style="color:var(--accent); font-size:.85rem; font-weight:600;">{{ tag }}</a>
    {% if not loop.last %}<span class="text-muted mx-1">|</span>{% endif %}
    {% endfor %}
</div>
{% endif %}

{# ===== HERO — Bootstrap grid responsive ===== #}
<div class="row g-4 mb-4 pb-4 border-bottom">
    {# Titre + excerpt #}
    <div class="col-lg-4 d-flex flex-column justify-content-start">
        <h1 style="font-size:1.9rem; font-weight:700; line-height:1.2; color:var(--text-dark);">
            <a href="{{ path('app_article', {slug: featured.slug}) }}" class="text-decoration-none" style="color:var(--text-dark);">{{ featured.title }}</a>
        </h1>
        {% if featured.excerpt %}
        <p class="mt-2 mb-2" style="color:var(--text); font-size:.9rem; line-height:1.55;">{{ featured.excerpt|length > 180 ? featured.excerpt[:180] ~ '...' : featured.excerpt }}</p>
        {% endif %}
        <div style="font-size:.78rem; color:var(--text-light);">
            {{ featured.publishedAt ? featured.publishedAt|date('d/m/Y') : '' }}
            · {{ (featured.content|striptags|split(' ')|length / 250)|round(0, 'ceil') }} min
        </div>
    </div>

    {# Image hero #}
    <div class="col-lg-5">
        {% if featured.imageUrl %}
        <a href="{{ path('app_article', {slug: featured.slug}) }}">
            <img src="{{ featured.imageUrl }}" alt="{{ featured.imageAlt ?? featured.title }}" loading="eager"
                 class="w-100" style="aspect-ratio:16/9; object-fit:cover;">
        </a>
        {% endif %}
    </div>

    {# "En continu" — masqué sur mobile/tablette #}
    <div class="col-lg-3 d-none d-lg-block">
        <div style="border-left:3px solid var(--accent); padding-left:1rem; height:100%; overflow:hidden;">
            <h4 style="font-weight:700; font-size:.85rem; text-transform:uppercase; letter-spacing:.03em; color:var(--text-dark); margin-bottom:.6rem;">En continu</h4>
            {% for article in articles|slice(1, 6) %}
            <div class="py-1 border-bottom {% if loop.last %}border-0{% endif %}">
                <div style="font-size:.7rem; color:var(--accent); font-weight:600;">{{ article.publishedAt ? article.publishedAt|date('H:i') : '' }}</div>
                <a href="{{ path('app_article', {slug: article.slug}) }}" class="text-decoration-none" style="color:var(--text-dark); font-size:.8rem; font-weight:600; line-height:1.3;">
                    {{ article.title|length > 55 ? article.title[:55] ~ '...' : article.title }}
                </a>
            </div>
            {% endfor %}
            <div class="text-center mt-2">
                <a href="{{ path('app_category_actualites') }}" class="btn btn-outline-primary btn-sm rounded-pill" style="font-size:.78rem;">Voir plus ›</a>
            </div>
        </div>
    </div>
</div>

{# ===== 3 CARDS — responsive: 1 col mobile, 2 tablette, 3 desktop ===== #}
{% if articles|length > 1 %}
<div class="row g-3 mb-4 pt-3 border-top">
    {% for article in articles|slice(1, 4) %}
    <div class="col-12 col-sm-6 col-lg-4">
        {% if article.imageUrl %}
        <a href="{{ path('app_article', {slug: article.slug}) }}">
            <img src="{{ article.imageUrl }}" alt="{{ article.imageAlt ?? article.title }}" loading="lazy"
                 class="w-100 mb-2" style="aspect-ratio:16/9; object-fit:cover;">
        </a>
        {% endif %}
        <span class="badge {{ article.category == 'evergreen' ? 'bg-info' : 'bg-danger' }} mb-1" style="font-size:.65rem;">{{ article.category == 'evergreen' ? 'GUIDE' : 'ACTU' }}</span>
        <h3 style="font-size:1rem; font-weight:700; line-height:1.3;">
            <a href="{{ path('app_article', {slug: article.slug}) }}" class="text-decoration-none" style="color:var(--text-dark);">{{ article.title }}</a>
        </h3>
    </div>
    {% endfor %}
</div>
{% endif %}

{# ===== HORIZONTAL CARDS — responsive: 1 col mobile, 2 tablette ===== #}
{% if articles|length > 4 %}
<div class="row g-3 mb-4">
    {% for article in articles|slice(4, 4) %}
    <div class="col-12 col-md-6">
        <div class="d-flex gap-3 align-items-start">
            {% if article.imageUrl %}
            <a href="{{ path('app_article', {slug: article.slug}) }}" class="flex-shrink-0">
                <img src="{{ article.imageUrl }}" alt="{{ article.imageAlt ?? article.title }}" loading="lazy"
                     style="width:150px; height:100px; object-fit:cover;">
            </a>
            {% endif %}
            <div>
                <span class="badge {{ article.category == 'evergreen' ? 'bg-info' : 'bg-danger' }} mb-1" style="font-size:.6rem;">{{ article.category == 'evergreen' ? 'GUIDE' : 'ACTU' }}</span>
                <h3 style="font-size:.9rem; font-weight:700; line-height:1.3; margin:0;">
                    <a href="{{ path('app_article', {slug: article.slug}) }}" class="text-decoration-none" style="color:var(--text-dark);">{{ article.title }}</a>
                </h3>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}

{# ===== GRILLE ARTICLES RESTANTS ===== #}
{% if articles|length > 8 %}
<div class="border-top pt-3 mb-4" style="border-width:3px !important; border-color:var(--text-dark) !important;">
    <div class="row g-3">
        {% for article in articles|slice(8) %}
        <div class="col-12 col-sm-6 col-lg-4">
            <div class="article-card h-100">
                {% if article.imageUrl %}
                <a href="{{ path('app_article', {slug: article.slug}) }}">
                    <img src="{{ article.imageUrl }}" alt="{{ article.imageAlt ?? article.title }}" loading="lazy">
                </a>
                {% endif %}
                <div class="card-body">
                    <span class="badge {{ article.category == 'evergreen' ? 'bg-info' : 'bg-danger' }} mb-1" style="font-size:.6rem;">{{ article.category == 'evergreen' ? 'GUIDE' : 'ACTU' }}</span>
                    <h3 class="card-title"><a href="{{ path('app_article', {slug: article.slug}) }}">{{ article.title }}</a></h3>
                    <div style="font-size:.75rem; color:var(--text-light); margin-top:.3rem;">
                        {{ article.publishedAt ? article.publishedAt|date('d/m/Y') : '' }}
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>
{% endif %}

{# PAGINATION #}
{% if pages > 1 %}
<nav class="d-flex justify-content-center mt-4 mb-4">
    <ul class="pagination">
        <li class="page-item {{ page <= 1 ? 'disabled' : '' }}"><a class="page-link" href="?page={{ page - 1 }}">&laquo;</a></li>
        {% for p in range(max(1, page - 3), min(pages, page + 3)) %}
        <li class="page-item {{ p == page ? 'active' : '' }}"><a class="page-link" href="?page={{ p }}">{{ p }}</a></li>
        {% endfor %}
        <li class="page-item {{ page >= pages ? 'disabled' : '' }}"><a class="page-link" href="?page={{ page + 1 }}">&raquo;</a></li>
    </ul>
</nav>
{% endif %}

{% endif %}
{% endblock %}
