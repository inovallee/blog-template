{% extends 'base.html.twig' %}

{% block title %}{{ app.request.host }} — Blog{% endblock %}
{% block meta %}
<meta name="description" content="Découvrez nos articles, guides et actualités sur {{ app.request.host }}">
<link rel="canonical" href="https://{{ app.request.host }}/">
{% endblock %}

{% block hero %}
<section class="hero">
    <div class="container">
        <h1>Bienvenue sur {{ app.request.host }}</h1>
        <p class="mb-0">Guides experts, analyses et actualités pour professionnels</p>
    </div>
</section>
{% endblock %}

{% block body %}
{% if articles is empty %}
    <div class="text-center py-5">
        <i class="bi bi-journal-text display-1 text-muted"></i>
        <p class="mt-3 text-muted fs-5">Les articles arrivent bientôt.</p>
    </div>
{% else %}

<!-- Derniers articles -->
<h2 class="mb-4" style="font-weight:700; color:var(--primary);">Derniers articles</h2>

<div class="row g-4">
    {% for article in articles %}
    <div class="col-md-6 col-lg-4">
        <div class="article-card h-100">
            <div class="card-body d-flex flex-column">
                <div class="mb-2">
                    <span class="category-badge {{ article.category == 'evergreen' ? 'badge-evergreen' : 'badge-actualites' }}">
                        {{ article.category == 'evergreen' ? 'Guide' : 'Actualité' }}
                    </span>
                </div>
                <h3 class="card-title">
                    <a href="{{ path('app_article', {slug: article.slug}) }}" class="text-decoration-none text-dark">
                        {{ article.title }}
                    </a>
                </h3>
                <p class="card-text flex-grow-1">{{ article.excerpt|length > 150 ? article.excerpt[:150] ~ '...' : article.excerpt }}</p>
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <small class="text-muted">{{ article.publishedAt ? article.publishedAt|date('d/m/Y') : article.createdAt|date('d/m/Y') }}</small>
                    <a href="{{ path('app_article', {slug: article.slug}) }}" class="btn btn-sm btn-outline-primary">
                        Lire <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>

{% endif %}
{% endblock %}
