{% extends 'base.html.twig' %}

{% block title %}{{ app.request.host }} — Actualités{% endblock %}
{% block meta %}
<meta name="description" content="Actualités, faits divers et analyses sur {{ app.request.host }}">
<link rel="canonical" href="https://{{ app.request.host }}/">
{% endblock %}

{% block ticker %}
{% set actus = articles|filter(a => a.category == 'actualites') %}
{% if actus|length > 0 %}
<div class="ticker-wrap">
    <div class="ticker">
        {% for i in 0..1 %}
        {% for article in actus %}
        <span class="ticker-item">
            <i class="bi bi-lightning-fill"></i>
            <a href="{{ path('app_article', {slug: article.slug}) }}">{{ article.title }}</a>
        </span>
        {% endfor %}
        {% endfor %}
    </div>
</div>
{% endif %}
{% endblock %}

{% block body %}
{% if articles|length > 0 %}
{% set featured = articles|first %}

{# HERO — Le Parisien style: big image + title #}
<div class="row g-0 mb-4" style="border-bottom:2px solid var(--primary); padding-bottom:1.5rem;">
    {% if featured.imageUrl %}
    <div class="col-lg-7">
        <a href="{{ path('app_article', {slug: featured.slug}) }}">
            <img src="{{ featured.imageUrl }}" alt="{{ featured.imageAlt ?? featured.title }}" loading="eager"
                 style="width:100%; height:380px; object-fit:cover;">
        </a>
    </div>
    <div class="col-lg-5 ps-lg-4 d-flex flex-column justify-content-center pt-3 pt-lg-0">
    {% else %}
    <div class="col-12">
    {% endif %}
        <span class="category-pill mb-2">{{ featured.category == 'evergreen' ? 'Guide' : 'Actualité' }}</span>
        <h1 style="font-family:var(--serif); font-size:1.7rem; font-weight:900; line-height:1.25; margin-bottom:.8rem;">
            <a href="{{ path('app_article', {slug: featured.slug}) }}" class="text-decoration-none" style="color:var(--text-dark);">{{ featured.title }}</a>
        </h1>
        {% if featured.excerpt %}
        <p style="color:var(--text); font-size:.9rem; line-height:1.6;">{{ featured.excerpt|length > 200 ? featured.excerpt[:200] ~ '...' : featured.excerpt }}</p>
        {% endif %}
        <div style="font-size:.78rem; color:var(--text-light);">
            <i class="bi bi-calendar3 me-1"></i>{{ featured.publishedAt ? featured.publishedAt|date('d/m/Y') : '' }}
            <span class="ms-2"><i class="bi bi-clock me-1"></i>{{ (featured.content|striptags|split(' ')|length / 250)|round(0, 'ceil') }} min</span>
        </div>
    </div>
</div>

{# MAIN GRID: Articles + Sidebar "En continu" #}
<div class="row g-4 mb-4">
    <div class="col-lg-8">
        {# Articles grid with images #}
        <div class="row g-3">
            {% for article in articles|slice(1, 6) %}
            <div class="col-md-6">
                <div class="article-card h-100">
                    {% if article.imageUrl %}
                    <a href="{{ path('app_article', {slug: article.slug}) }}">
                        <img src="{{ article.imageUrl }}" alt="{{ article.imageAlt ?? article.title }}" loading="lazy">
                    </a>
                    {% endif %}
                    <div class="card-body">
                        <span class="category-pill mb-1" style="font-size:.6rem;">{{ article.category == 'evergreen' ? 'Guide' : 'Actualité' }}</span>
                        <h3 class="card-title"><a href="{{ path('app_article', {slug: article.slug}) }}">{{ article.title }}</a></h3>
                        <div style="font-size:.75rem; color:var(--text-light); margin-top:.5rem;">
                            {{ article.publishedAt ? article.publishedAt|date('d/m/Y') : '' }}
                            · {{ (article.content|striptags|split(' ')|length / 250)|round(0, 'ceil') }} min
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

    {# Sidebar "En continu" #}
    <div class="col-lg-4">
        <div class="sidebar-continu">
            <h4>En continu</h4>
            {% for article in articles|slice(1, 12) %}
            <div class="sidebar-item">
                <a href="{{ path('app_article', {slug: article.slug}) }}">{{ article.title }}</a>
                <div class="meta">{{ article.publishedAt ? article.publishedAt|date('d/m/Y') : '' }}</div>
            </div>
            {% endfor %}
        </div>
    </div>
</div>

{# SECTIONS PAR VILLE #}
{% if citySections is defined and citySections|length > 0 %}
<div class="mb-4">
    <div class="section-header">
        <h2><i class="bi bi-geo-alt-fill me-1"></i> Par ville</h2>
    </div>
    <div class="row g-3">
        {% for section in citySections %}
        <div class="col-md-6 col-lg-4">
            <div style="border:1px solid var(--border); overflow:hidden;">
                <div style="background:var(--primary); color:#fff; padding:.5rem 1rem; font-weight:600; font-size:.85rem;">
                    <a href="{{ path('app_city', {city: section.city}) }}" class="text-white text-decoration-none">
                        {{ section.city }} <span style="opacity:.6; font-size:.75rem;">({{ section.count }})</span>
                    </a>
                </div>
                <div style="padding:.6rem 1rem;">
                    {% for art in section.articles[:3] %}
                    <div style="padding:.35rem 0; {{ not loop.last ? 'border-bottom:1px solid var(--border);' : '' }}">
                        <a href="/{{ art.slug }}" class="text-decoration-none" style="color:var(--text-dark); font-size:.82rem; font-weight:500; line-height:1.3; display:block;">
                            {{ art.title|length > 80 ? art.title[:80] ~ '...' : art.title }}
                        </a>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>
{% endif %}

{# SECTIONS PAR TYPE #}
{% if typeSections is defined and typeSections|length > 0 %}
<div class="mb-4">
    <div class="section-header">
        <h2><i class="bi bi-tag-fill me-1"></i> Par catégorie</h2>
    </div>
    <div class="row g-3">
        {% for section in typeSections %}
        <div class="col-md-6 col-lg-4">
            <div style="border:1px solid var(--border); overflow:hidden;">
                <div style="background:var(--accent); color:#fff; padding:.5rem 1rem; font-weight:600; font-size:.85rem;">
                    <a href="{{ path('app_type', {eventType: section.type}) }}" class="text-white text-decoration-none">
                        {{ section.label }} <span style="opacity:.7; font-size:.75rem;">({{ section.count }})</span>
                    </a>
                </div>
                <div style="padding:.6rem 1rem;">
                    {% for art in section.articles[:3] %}
                    <div style="padding:.35rem 0; {{ not loop.last ? 'border-bottom:1px solid var(--border);' : '' }}">
                        <a href="/{{ art.slug }}" class="text-decoration-none" style="color:var(--text-dark); font-size:.82rem; font-weight:500; line-height:1.3; display:block;">
                            {{ art.title|length > 80 ? art.title[:80] ~ '...' : art.title }}
                        </a>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>
{% endif %}

{# TOUS LES ARTICLES — grille paginée #}
{% if articles|length > 7 %}
<div class="mb-4">
    <div class="section-header">
        <h2>Tous les articles <span style="font-weight:400; font-size:.82rem; color:var(--text-light);">({{ total }})</span></h2>
    </div>
    <div class="row g-3">
        {% for article in articles %}
        {% if not loop.first or page > 1 %}
        <div class="col-md-6 col-lg-4">
            <div class="article-card h-100">
                {% if article.imageUrl %}
                <a href="{{ path('app_article', {slug: article.slug}) }}">
                    <img src="{{ article.imageUrl }}" alt="{{ article.imageAlt ?? article.title }}" loading="lazy">
                </a>
                {% endif %}
                <div class="card-body">
                    <span class="category-pill mb-1" style="font-size:.6rem;">{{ article.category == 'evergreen' ? 'Guide' : 'Actualité' }}</span>
                    <h3 class="card-title"><a href="{{ path('app_article', {slug: article.slug}) }}">{{ article.title }}</a></h3>
                    {% if article.excerpt %}
                    <p class="card-text" style="margin-top:.3rem;">{{ article.excerpt|length > 100 ? article.excerpt[:100] ~ '...' : article.excerpt }}</p>
                    {% endif %}
                    <div style="font-size:.75rem; color:var(--text-light); margin-top:.5rem;">
                        {{ article.publishedAt ? article.publishedAt|date('d/m/Y') : '' }}
                    </div>
                </div>
            </div>
        </div>
        {% endif %}
        {% endfor %}
    </div>
</div>
{% endif %}

{# PAGINATION #}
{% if pages > 1 %}
<nav class="d-flex justify-content-center mt-4 mb-4">
    <ul class="pagination">
        <li class="page-item {{ page <= 1 ? 'disabled' : '' }}">
            <a class="page-link" href="?page={{ page - 1 }}">&laquo;</a>
        </li>
        {% for p in range(max(1, page - 3), min(pages, page + 3)) %}
        <li class="page-item {{ p == page ? 'active' : '' }}">
            <a class="page-link" href="?page={{ p }}">{{ p }}</a>
        </li>
        {% endfor %}
        <li class="page-item {{ page >= pages ? 'disabled' : '' }}">
            <a class="page-link" href="?page={{ page + 1 }}">&raquo;</a>
        </li>
    </ul>
</nav>
{% endif %}

{% endif %}
{% endblock %}
