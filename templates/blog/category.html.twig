{% extends 'base.html.twig' %}

{% block title %}{{ categoryName }} — {{ app.request.host }}{% endblock %}
{% block meta %}
<meta name="description" content="{{ categoryName }} : articles et guides sur {{ app.request.host }}">
<link rel="canonical" href="https://{{ app.request.host }}/{{ categorySlug }}">
{% endblock %}

{% block body %}
<h1 class="mb-4" style="font-weight:700; color:var(--primary);">{{ categoryName }}</h1>

{% if articles is empty %}
    <p class="text-muted">Aucun article dans cette catégorie pour le moment.</p>
{% else %}
<div class="row g-4">
    {% for article in articles %}
    <div class="col-md-6">
        <div class="article-card h-100">
            <div class="card-body">
                <h3 class="card-title">
                    <a href="{{ path('app_article', {slug: article.slug}) }}" class="text-decoration-none text-dark">{{ article.title }}</a>
                </h3>
                <p class="card-text">{{ article.excerpt|length > 200 ? article.excerpt[:200] ~ '...' : article.excerpt }}</p>
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <small class="text-muted">{{ article.publishedAt ? article.publishedAt|date('d/m/Y') : '' }}</small>
                    <a href="{{ path('app_article', {slug: article.slug}) }}" class="btn btn-sm btn-outline-primary">Lire <i class="bi bi-arrow-right ms-1"></i></a>
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}
{% endblock %}
