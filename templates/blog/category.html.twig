{% extends 'base.html.twig' %}

{% block ticker %}
{% set actus = articles|filter(a => a.category == 'actualites') %}
{% if actus|length > 0 %}
<div class="ticker-wrap">
    <div class="ticker">
        {% for i in 0..1 %}
        {% for a in actus %}
        <span class="ticker-item">
            <i class="bi bi-lightning-fill"></i>
            <a href="{{ path('app_article', {slug: a.slug}) }}">{{ a.title }}</a>
        </span>
        {% endfor %}
        {% endfor %}
    </div>
</div>
{% endif %}
{% endblock %}

{% block title %}{{ categoryName }} — {{ app.request.host }}{% endblock %}
{% block meta %}
<meta name="description" content="{{ categoryName }} : articles et guides experts sur {{ app.request.host }}">
<link rel="canonical" href="https://{{ app.request.host }}/{{ categorySlug }}">
{% endblock %}

{% block body %}
<div class="section-header mt-2">
    <h2>{{ categoryName }}</h2>
    <span style="color:var(--text-light); font-size:.85rem;">{{ articles|length }} article{{ articles|length > 1 ? 's' : '' }}</span>
</div>

{% if articles is empty %}
    <div class="text-center py-5">
        <p style="color:var(--text-light);">Aucun article dans cette catégorie.</p>
    </div>
{% else %}
<div class="row g-3">
    {% for article in articles %}
    <div class="col-md-6 col-lg-4">
        <div class="article-card h-100">
            {% if article.imageUrl %}
            <a href="{{ path('app_article', {slug: article.slug}) }}">
                <img src="{{ article.imageUrl }}" alt="{{ article.imageAlt ?? article.title }}" loading="lazy">
            </a>
            {% endif %}
            <div class="card-body">
                <span class="category-pill mb-1" style="font-size:.6rem;">{{ article.category == 'evergreen' ? 'Guide' : 'Actualité' }}</span>
                <h3 class="card-title"><a href="{{ path('app_article', {slug: article.slug}) }}">{{ article.title }}</a></h3>
                {% if article.excerpt %}
                <p class="card-text" style="margin-top:.3rem;">{{ article.excerpt|length > 120 ? article.excerpt[:120] ~ '...' : article.excerpt }}</p>
                {% endif %}
                <div style="font-size:.75rem; color:var(--text-light); margin-top:.5rem;">
                    {{ article.publishedAt ? article.publishedAt|date('d/m/Y') : article.createdAt|date('d/m/Y') }}
                    · {{ (article.content|striptags|split(' ')|length / 250)|round(0, 'ceil') }} min
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}
{% endblock %}
