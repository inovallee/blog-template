{% extends 'base.html.twig' %}

{% block title %}{{ categoryName }} — {{ app.request.host }}{% endblock %}
{% block meta %}
<meta name="description" content="{{ categoryName }} : articles et guides experts sur {{ app.request.host }}">
<link rel="canonical" href="https://{{ app.request.host }}/{{ categorySlug }}">
{% endblock %}

{% block hero %}
<section class="hero" style="padding:2rem 0;">
    <div style="max-width:1200px; margin:0 auto; padding:0 1.5rem;">
        <p class="mb-1" style="font-size:.75rem; opacity:.5; text-transform:uppercase; letter-spacing:.12em; font-weight:600;">Catégorie</p>
        <h1 style="font-size:1.8rem; margin-bottom:.3rem;">{{ categoryName }}</h1>
        <p class="mb-0" style="opacity:.7; font-size:.9rem;">{{ articles|length }} article{{ articles|length > 1 ? 's' : '' }} disponible{{ articles|length > 1 ? 's' : '' }}</p>
    </div>
</section>
{% endblock %}

{% block body %}
{% if articles is empty %}
    <div class="text-center py-5">
        <i class="bi bi-journal-text display-1" style="color:var(--border);"></i>
        <p class="mt-3" style="color:var(--text-light);">Aucun article dans cette catégorie.</p>
    </div>
{% else %}
<div class="row g-4">
    {% for article in articles %}
    <div class="col-md-6">
        <div class="article-card h-100">
            <div class="card-body d-flex flex-column">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="category-pill">{{ article.category == 'evergreen' ? 'Guide' : 'Actualité' }}</span>
                    <span class="reading-time"><i class="bi bi-clock me-1"></i>{{ (article.content|striptags|split(' ')|length / 250)|round(0, 'ceil') }} min</span>
                </div>
                <h3 class="card-title flex-grow-1">
                    <a href="{{ path('app_article', {slug: article.slug}) }}" class="text-decoration-none" style="color:var(--text-dark);">{{ article.title }}</a>
                </h3>
                {% if article.excerpt %}
                <p class="card-text">{{ article.excerpt|length > 150 ? article.excerpt[:150] ~ '...' : article.excerpt }}</p>
                {% endif %}
                <div class="d-flex justify-content-between align-items-center mt-auto pt-3" style="border-top:1px solid var(--border);">
                    <small style="color:var(--text-light);">{{ article.publishedAt ? article.publishedAt|date('d/m/Y') : article.createdAt|date('d/m/Y') }}</small>
                    <a href="{{ path('app_article', {slug: article.slug}) }}" style="color:var(--accent); font-size:.82rem; font-weight:600;">Lire <i class="bi bi-arrow-right ms-1"></i></a>
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}
{% endblock %}
